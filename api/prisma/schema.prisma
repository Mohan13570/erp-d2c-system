// ==========================================
// MODULE 4 - SHIPMENT MANAGEMENT
// ==========================================
model Shipment {
  id             String    @id @default(uuid())
  trackingNumber String    @unique
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  shipper        String?
  consignee      String?
  notifyParty    String?
  incoterms      String?
  priority       String    @default("Standard")
  freightType    String
  transportMode  String?
