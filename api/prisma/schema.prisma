  heading   Float     @default(0.0)
  engineOn  Boolean   @default(false)
  fuelLevel Float?

  // Live Tracking Engine Properties
  estimatedETA     DateTime?
  distanceToDestKm Float?
  isBatched        Boolean   @default(false)
  bufferSequence   Int       @default(0)

  timestamp DateTime @default(now())
}

model Geofence {
  id          String          @id @default(uuid())
