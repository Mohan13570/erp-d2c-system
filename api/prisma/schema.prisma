  driverName     String?
  driverContact  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model VendorShipmentTracking {
  id        String                @id @default(uuid())
  asnId     String
  asn       AdvanceShipmentNotice @relation(fields: [asnId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event     String // Dispatched, In Transit, Arrived, Gate Entry, Unloading, Completed
  location  String?
  timestamp DateTime              @default(now())
}

model VendorGRNVisibility {
  id       String           @id @default(uuid())
  grnId    String
  grn      GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  vendorId String
  vendor   Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  canView  Boolean          @default(true)
  viewedAt DateTime?
}

// ==========================================
// VENDOR FINANCE & BILLING
// ==========================================

model VendorFinanceInvoice {
  id              String         @id @default(uuid())
  invoiceNumber   String         @unique
  vendorId        String
  vendor          Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  status          String         @default("Pending Approval") // Draft, Pending Approval, Approved, Rejected, Paid, Overdue
  totalAmount     Float          @default(0.0)
  taxAmount       Float          @default(0.0)
  currency        String         @default("USD")
  dueDate         DateTime?
  submittedAt     DateTime       @default(now())

  items         VendorFinanceInvoiceItem[]
  payments      VendorFinancePayment[]
  ledgerEntries VendorFinanceLedger[]
}

model VendorFinanceInvoiceItem {
  id          String               @id @default(uuid())
  invoiceId   String
  invoice     VendorFinanceInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float                @default(1.0)
  unitPrice   Float                @default(0.0)
  totalPrice  Float                @default(0.0)
}

model VendorFinancePayment {
  id          String                @id @default(uuid())
  paymentRef  String                @unique
  vendorId    String
  vendor      Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invoiceId   String?
  invoice     VendorFinanceInvoice? @relation(fields: [invoiceId], references: [id])
  amount      Float                 @default(0.0)
  currency    String                @default("USD")
  status      String                @default("Processing") // Pending, Processing, Paid, Failed
  paymentDate DateTime?
  createdAt   DateTime              @default(now())

  ledgerEntries VendorFinanceLedger[]
}

model VendorFinanceLedger {
  id            String  @id @default(uuid())
  vendorId      String
  vendor        Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type          String // Invoice, Payment, Credit Note, Debit Note
  description   String?
  debitAmount   Float   @default(0.0)
  creditAmount  Float   @default(0.0)
  balanceAmount Float   @default(0.0)

  invoiceId String?
  invoice   VendorFinanceInvoice? @relation(fields: [invoiceId], references: [id])
  paymentId String?
  payment   VendorFinancePayment? @relation(fields: [paymentId], references: [id])

  transactionDate DateTime @default(now())
}

model VendorTaxDocument {
  id           String    @id @default(uuid())
  vendorId     String
  vendor       Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  documentType String // GST Return, TDS Certificate, Tax Registration
  documentUrl  String
  uploadDate   DateTime  @default(now())
  expiryDate   DateTime?
}

// ==========================================
// VENDOR COLLABORATION, SUPPORT & ANALYTICS
// ==========================================

model VendorSupportTicket {
  id           String   @id @default(uuid())
  ticketNumber String   @unique
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category     String // Technical, Finance, Procurement, Logistics
  priority     String   @default("Medium") // Low, Medium, High, Critical
  subject      String
  description  String
  status       String   @default("Open") // Open, In Progress, Resolved, Closed
  resolution   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VendorChatMessage {
  id            String   @id @default(uuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  sender        String // "Vendor" or "Admin"
  message       String
  attachmentUrl String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model VendorKnowledgeArticle {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String // FAQs, Manuals, Guides
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorPerformanceMetric {
  id              String   @id @default(uuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  month           String // e.g., "2026-07"
  onTimeDelivery  Float    @default(100.0) // Percentage
  invoiceAccuracy Float    @default(100.0) // Percentage
  qualityScore    Float    @default(5.0) // Out of 5
  createdAt       DateTime @default(now())
}

model VendorDeveloperApp {
  id         String   @id @default(uuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  appName    String
  apiKey     String   @unique
  webhookUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

