datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// PLATFORM: COMPANY & MULTI-TENANCY
// ==========================================
model Company {
  id           String  @id @default(uuid())
  companyCode  String  @unique @default("CMP-001")
  name         String  @unique // Keeping 'name' unique to support existing relations
  legalName    String?
  tradeName    String?
  businessType String?

  // Hierarchy
  isHoldingCompany Boolean   @default(false)
  parentCompanyId  String?
  parentCompany    Company?  @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id])
  subsidiaries     Company[] @relation("CompanyHierarchy")

  // Registrations & Taxes
  gstRegistration  String?
  pan              String?
  tan              String?
  iecNumber        String?
  msmeRegistration String?
  businessLicense  String?
  taxConfiguration String?

  // Contact Info
  corporateWebsite String?
  officialEmail    String?
  supportEmail     String?
  officialPhone    String?
  emergencyContact String?

  // Status & Audit
  status    String   @default("Active") // Draft, Active, Inactive, Suspended, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  // Existing Fields to maintain compatibility
  abbr            String?
  defaultCurrency String  @default("USD")
  country         String  @default("US")
  taxId           String?
  fiscalYearStart String  @default("01-01")
  logoUrl         String?

  // Existing Relations
  items              Item[]
  employees          Employee[]
  accounts           Account[]
  salesOrders        SalesOrder[]
  vendors            Vendor[]
  purchaseOrders     PurchaseOrder[]
  assets             Asset[]
  projects           Project[]
  fiscalPeriods      FiscalPeriod[]
  departments        Department[]
  payrollRuns        PayrollRun[]
  warehouses         Warehouse[]
  marketingCampaigns MarketingCampaign[]
  branches           Branch[]

  // New Enterprise Relations
  companyAddresses CompanyAddress[]
  companyContacts  CompanyContact[]
  companyDocuments CompanyDocument[]
  companyBranding  CompanyBranding?
  companySettings  CompanySettings?
  businessUnits    BusinessUnit[]
  warehouseLinks   WarehouseAssignment[]
}

model CompanyAddress {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  addressType String   @default("Head Office") // Head Office, Registered Office, Billing, Shipping
  line1       String
  line2       String?
  city        String
  state       String?
  country     String
  postalCode  String
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyContact {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  contactName String
  designation String?
  email       String
  phone       String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyDocument {
  id           String    @id @default(uuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  documentType String // Certificate, License, Insurance Policy, Contract, Agreement
  documentName String
  fileUrl      String
  version      String    @default("1.0")
  issueDate    DateTime?
  expiryDate   DateTime?
  status       String    @default("Active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CompanyBranding {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  company             Company  @relation(fields: [companyId], references: [id])
  logoUrl             String?
  faviconUrl          String?
  theme               String   @default("light")
  brandColorPrimary   String?
  brandColorSecondary String?
  typography          String?
  digitalSignatureUrl String?
  watermarkUrl        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CompanySettings {
  id              String   @id @default(uuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id])
  invoiceBranding String?
  emailBranding   String?
  letterheadUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// AUTH & RBAC
// ==========================================
model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  firstName        String
  lastName         String
  userRoles        UserRole[]
  securityPolicies SecurityPolicy[]
  mfas             MFA[]
  otps             OTP[]
  refreshTokens    RefreshToken[]
  apiKeys          APIKey[]

  // Status
  status     String  @default("Pending") // Pending, Active, Inactive, Locked, Blocked, Suspended, Deleted
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  // Relations
  employeeProfile EmployeeProfile?
  devices         UserDevice[]
  sessions        UserSession[]
  loginHistory    LoginHistory[]
  preferences     UserPreference?
  auditLogs       AuditLog[]
  notifications   NotificationRecipient[]

  // Auditing
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  category    String  @default("Custom") // System, Business, Custom
  isSystem    Boolean @default(false)

  userRoles   UserRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermissionCategory {
  id          String       @id @default(uuid())
  name        String       @unique // e.g. "Inventory", "Finance"
  description String?
  permissions Permission[]
}

model Permission {
  id          String  @id @default(uuid())
  action      String // View, Create, Edit, Delete, Approve, Export
  module      String // Inventory, Finance, Users
  description String?

  categoryId String?
  category   PermissionCategory? @relation(fields: [categoryId], references: [id])

  roles RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // Scoped Role Assignment (e.g. Role only applies to specific Branch)
  entityType String? // Branch, Department, Company
  entityId   String?

  validFrom  DateTime?
  validUntil DateTime?

  @@unique([userId, roleId, entityId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  tableName String
  recordId  String
  oldValue  String?
  newValue  String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ==========================================
// D2C CUSTOMER ACCOUNTS
// ==========================================
model D2CCustomer {
  id            String            @id @default(uuid())
  email         String            @unique
  phone         String?
  passwordHash  String?
  firstName     String
  lastName      String
  isGuest       Boolean           @default(false)
  loyaltyPoints Int               @default(0)
  tier          String            @default("Bronze")
  createdAt     DateTime          @default(now())
  orders        SalesOrder[]
  carts         Cart[]
  returns       Return[]
  addresses     CustomerAddress[]
}

model CustomerAddress {
  id         String      @id @default(uuid())
  customerId String
  customer   D2CCustomer @relation(fields: [customerId], references: [id])
  label      String      @default("Home")
  line1      String
  line2      String?
  city       String
  state      String?
  country    String
  postalCode String
  isDefault  Boolean     @default(false)
}

// ==========================================
// ERP CUSTOMER (B2B / CRM)
// ==========================================
model Customer {
  id            String   @id @default(uuid())
  customerCode  String   @unique @default("CUST-001")
  legalName     String   @default("TBD")
  tradeName     String?
  customerName  String // Keeping for backward compatibility
  customerGroup String   @default("Commercial")
  territory     String?
  email         String?
  phone         String?
  status        String   @default("Pending Approval")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salesOrders    SalesOrder[]
  invoices       Invoice[]
  rfqs           RFQ[]
  shipments      Shipment[]
  contacts       CustomerContact[]
  contracts      CustomerContract[]
  opportunities  Opportunity[]
  activities     LeadActivity[]
  supportTickets SupportTicket[]

  profile                 CustomerProfile?
  addresses               B2BCustomerAddress[]
  branches                CustomerBranch[]
  banks                   CustomerBank[]
  documents               CustomerDocument[]
  compliance              CustomerCompliance?
  kyc                     CustomerKYC?
  users                   CustomerUser[]
  invitations             CustomerInvitation[]
  arInvoices              ARInvoice[]
  CustomerShipmentBooking CustomerShipmentBooking[]
  customerBookings        CustomerBooking[]
}

model Supplier {
  id            String   @id @default(uuid())
  supplierName  String
  supplierGroup String   @default("Local")
  email         String?
  phone         String?
  vendors       Vendor[]
}

// ==========================================
// SUPPLY CHAIN / PROCUREMENT
// ==========================================
model Vendor {
  asns                   AdvanceShipmentNotice[]
  id                     String                  @id @default(uuid())
  name                   String
  supplierId             String?
  supplier               Supplier?               @relation(fields: [supplierId], references: [id])
  companyName            String?
  company                Company?                @relation(fields: [companyName], references: [name])
  email                  String?
  phone                  String?
  country                String?
  paymentTerms           String?
  purchaseOrders         PurchaseOrder[]
  procurementVendorBills ProcurementVendorBill[] @relation("ProcurementVendorBills")
  procurementPayments    ProcurementPayment[]    @relation("ProcurementPayments")
  vendorLedgers          VendorLedger[]

  createdAt DateTime @default(now())

  // New Fields for Vendor Management
  status         String  @default("Active") // Active, Inactive, Blacklisted, Pending
  registrationNo String?
  gstNo          String?
  panNo          String?
  website        String?
  currency       String  @default("USD")
  creditLimit    Float   @default(0.0)
  rating         Float   @default(0.0)

  // Relations
  contacts       VendorContact[]
  addresses      VendorAddress[]
  bankAccounts   VendorBankAccount[]
  documents      VendorDocument[]
  certifications VendorCertification[]
  contracts      VendorContract[]
  products       VendorProduct[]
  services       VendorService[]
  rates          VendorRate[]
  performances   VendorPerformance[]
  scorecards     VendorScorecard[]
  risks          VendorRisk[]
  taxes          VendorTax[]
  auditLogs      VendorAuditLog[]
  rfqVendors     ProcurementRFQVendor[]
  rfqResponses   ProcurementRFQResponse[]

  // Categorization
  categoryId String?
  category   VendorCategory? @relation(fields: [categoryId], references: [id])
  groupId    String?
  group      VendorGroup?    @relation(fields: [groupId], references: [id])
  typeId     String?
  type       VendorType?     @relation(fields: [typeId], references: [id])

  // Vendor Portal Extensions
  profile                 VendorProfile?
  users                   VendorUser[]
  invitations             VendorInvitation[]
  compliance              VendorCompliance?
  kycDocuments            VendorKYC[]
  approvals               VendorApproval[]
  notifications           VendorNotification[]
  activities              VendorActivity[]
  quotations              VendorQuotation[]
  catalogs                VendorProductCatalog[]
  priceLists              VendorPriceList[]
  poInteractions          VendorPOInteraction[]
  contractAcknowledgments VendorContractAcknowledge[]
  asnInteractions         VendorASNInteraction[]
  deliveryAppointments    VendorDeliveryAppointment[]
  shipmentTrackings       VendorShipmentTracking[]
  grnVisibilities         VendorGRNVisibility[]
  financeInvoices         VendorFinanceInvoice[]
  financePayments         VendorFinancePayment[]
  financeLedgerEntries    VendorFinanceLedger[]
  taxDocuments            VendorTaxDocument[]
  supportTickets          VendorSupportTicket[]
  chatMessages            VendorChatMessage[]
  performanceMetrics      VendorPerformanceMetric[]
  developerApps           VendorDeveloperApp[]
}

// ==========================================
// INVENTORY (ITEM MASTER & STOCK)
// ==========================================
model Item {
  pickListItems           PickListItem[]
  batches                 InventoryBatch[]
  serials                 InventorySerial[]
  adjustments             InventoryAdjustment[]
  transfers               InventoryTransfer[]
  itemCode                String                    @id
  itemName                String
  itemGroup               String                    @default("Products")
  description             String?
  stockUom                String                    @default("Nos")
  standardRate            Float                     @default(0.0)
  valuationRate           Float                     @default(0.0)
  imageUrl                String?
  companyName             String?
  company                 Company?                  @relation(fields: [companyName], references: [name])
  isActive                Boolean                   @default(true)
  isD2cVisible            Boolean                   @default(true)
  taxRate                 Float                     @default(0.0)
  weight                  Float?
  stockEntries            StockLedgerEntry[]
  orderItems              SalesOrderItem[]
  stockLevels             StockLevel[]
  variants                ProductVariant[]
  bomItems                BOMItem[]
  bom                     BOM?
  poItems                 POItem[]
  grnItems                GRNItem[]
  createdAt               DateTime                  @default(now())
  PurchaseRequisitionItem PurchaseRequisitionItem[]
  PurchaseReturnItem      PurchaseReturnItem[]
  PutAwayItem             PutAwayItem[]
}

model ProductVariant {
  id            String   @id @default(uuid())
  itemCode      String
  item          Item     @relation(fields: [itemCode], references: [itemCode])
  sku           String   @unique
  attributes    String // JSON: {"size":"L","color":"Blue"}
  priceOverride Float?
  barcode       String?
  createdAt     DateTime @default(now())
}

model Warehouse {
  name        String  @id
  code        String? @unique
  companyName String
  company     Company @relation(fields: [companyName], references: [name])

  // WMS Master Data
  category          String? // e.g., Regional, Local
  type              String? // Cold Storage, Dry, Bonded, Cross Dock
  capacity          Float?
  storageConditions String? // Ambient, Chilled, Frozen
  gpsCoordinates    String?
  managerName       String?
  status            String  @default("Active") // Active, Maintenance, Closed

  stockEntries StockLedgerEntry[]
  stockLevels  StockLevel[]
  locations    WarehouseLocation[]

  // New Spatial & Asset Relations
  zones       WarehouseZone[]
  assignments WarehouseAssignment[]
  equipments  WarehouseEquipment[]
  loadingBays LoadingBay[]
  shifts      WarehouseShift[]
  holidays    WarehouseHoliday[]
  settings    WarehouseSetting?
  documents   WarehouseDocument[]
  images      WarehouseImage[]
  safetyRules SafetyRule[]
}

model StockLevel {
  id            String    @id @default(uuid())
  itemCode      String
  item          Item      @relation(fields: [itemCode], references: [itemCode])
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name])
  qtyOnHand     Float     @default(0.0)
  qtyReserved   Float     @default(0.0)
  qtyAvailable  Float     @default(0.0)
  qtyBlocked    Float     @default(0.0)
  qtyDamaged    Float     @default(0.0)
  qtyExpired    Float     @default(0.0)
  updatedAt     DateTime  @updatedAt

  @@unique([itemCode, warehouseName])
}

model StockLedgerEntry {
  id           String    @id @default(uuid())
  itemCode     String
  item         Item      @relation(fields: [itemCode], references: [itemCode])
  warehouse    String
  warehouseRef Warehouse @relation(fields: [warehouse], references: [name])
  qty          Float
  voucherType  String
  voucherNo    String
  postingDate  DateTime  @default(now())
}

// ==========================================
// MANUFACTURING
// ==========================================
model BOM {
  id         String      @id @default(uuid())
  itemCode   String      @unique
  item       Item        @relation(fields: [itemCode], references: [itemCode])
  quantity   Float       @default(1.0)
  isActive   Boolean     @default(true)
  bomItems   BOMItem[]
  workOrders WorkOrder[]
  createdAt  DateTime    @default(now())
}

model BOMItem {
  id       String @id @default(uuid())
  bomId    String
  bom      BOM    @relation(fields: [bomId], references: [id])
  itemCode String
  item     Item   @relation(fields: [itemCode], references: [itemCode])
  qty      Float
  uom      String @default("Nos")
}

model WorkOrder {
  id           String    @id @default(uuid())
  bomId        String
  bom          BOM       @relation(fields: [bomId], references: [id])
  plannedQty   Float
  producedQty  Float     @default(0.0)
  status       String    @default("Draft")
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  createdAt    DateTime  @default(now())
}

// ==========================================
// PROJECT MANAGEMENT
// ==========================================
model Project {
  id          String    @id @default(uuid())
  name        String
  status      String    @default("Open")
  companyName String?
  company     Company?  @relation(fields: [companyName], references: [name])
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  customerId  String?
  tasks       Task[]
  createdAt   DateTime  @default(now())
}

model Task {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  subject     String
  status      String    @default("Open")
  priority    String    @default("Medium")
  assignedTo  String?
  dueDate     DateTime?
  completedOn DateTime?
  createdAt   DateTime  @default(now())
}

// ==========================================
// ASSET MANAGEMENT
// ==========================================
model Asset {
  id                 String    @id @default(uuid())
  assetName          String
  assetCategory      String
  companyName        String?
  company            Company?  @relation(fields: [companyName], references: [name])
  purchaseDate       DateTime?
  purchaseAmount     Float     @default(0.0)
  currentValue       Float     @default(0.0)
  depreciationMethod String    @default("Straight Line")
  usefulLifeYears    Int       @default(5)
  status             String    @default("Active")
  location           String?
  createdAt          DateTime  @default(now())
}

// ==========================================
// FINANCE (GENERAL LEDGER, INVOICES, PAYMENTS)
// ==========================================
model FiscalPeriod {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("Open")
  year        Int
  companyName String?
  company     Company? @relation(fields: [companyName], references: [name])
}

model Account {
  name           String             @id
  code           String?
  accountType    String
  rootType       String
  parentId       String?
  currency       String             @default("USD")
  isActive       Boolean            @default(true)
  companyName    String?
  company        Company?           @relation(fields: [companyName], references: [name])
  glEntries      GLEntry[]
  journalLines   JournalEntryLine[]
  debitInvoices  Invoice[]          @relation("DebitAccount")
  creditInvoices Invoice[]          @relation("CreditAccount")
}

model JournalEntry {
  id          String             @id @default(uuid())
  reference   String?
  date        DateTime           @default(now())
  description String?
  status      String             @default("Draft")
  period      String?
  createdBy   String?
  postedAt    DateTime?
  lines       JournalEntryLine[]
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountName    String
  account        Account      @relation(fields: [accountName], references: [name])
  debit          Float        @default(0.0)
  credit         Float        @default(0.0)
  currency       String       @default("USD")
  exchangeRate   Float        @default(1.0)
  description    String?
}

model Invoice {
  id                String    @id @default(uuid())
  type              String // "AP" or "AR"
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  date              DateTime  @default(now())
  dueDate           DateTime?
  status            String    @default("Draft")
  subtotal          Float     @default(0.0)
  tax               Float     @default(0.0)
  total             Float     @default(0.0)
  currency          String    @default("USD")
  debitAccountName  String?
  debitAccount      Account?  @relation("DebitAccount", fields: [debitAccountName], references: [name])
  creditAccountName String?
  creditAccount     Account?  @relation("CreditAccount", fields: [creditAccountName], references: [name])
  payments          Payment[]
}

model Payment {
  id         String   @id @default(uuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id])
  amount     Float
  method     String   @default("Bank Transfer")
  reference  String?
  gatewayId  String?
  status     String   @default("Pending")
  reconciled Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model GLEntry {
  id          String   @id @default(uuid())
  account     String
  accountRef  Account  @relation(fields: [account], references: [name])
  debit       Float    @default(0.0)
  credit      Float    @default(0.0)
  voucherType String
  voucherNo   String
  postingDate DateTime @default(now())
}

// ==========================================
// HR & PAYROLL
// ==========================================
model Department {
  id             String @id @default(uuid())
  departmentCode String @unique @default("DEPT-001")
  name           String

  // Hierarchy
  parentId       String?
  parent         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  subDepartments Department[] @relation("DepartmentHierarchy")

  // Company linking
  companyName String?
  company     Company? @relation(fields: [companyName], references: [name])

  // New Enterprise Links
  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])

  headId String?
  budget Float   @default(0.0)
  kpis   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees     Employee[]
  costCenters   CostCenter[]
  profitCenters ProfitCenter[]
}

model Employee {
  employee       String          @id @default(uuid())
  userId         String?
  employeeName   String
  companyName    String?
  company        Company?        @relation(fields: [companyName], references: [name])
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id])
  designation    String?
  managerId      String?
  employmentType String          @default("Full-time")
  joinDate       DateTime        @default(now())
  salary         Float?
  status         String          @default("Active")
  attendanceLogs AttendanceLog[]
  payslips       Payslip[]
  attendances    Attendance[]
  payrolls       Payroll[]
  createdAt      DateTime        @default(now())
}

model AttendanceLog {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [employee])
  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?
  source      String    @default("Manual")
  hoursWorked Float?
}

model PayrollRun {
  id              String    @id @default(uuid())
  period          String
  status          String    @default("Draft")
  totalGross      Float     @default(0.0)
  totalNet        Float     @default(0.0)
  totalDeductions Float     @default(0.0)
  approvedBy      String?
  processedAt     DateTime?
  companyName     String?
  company         Company?  @relation(fields: [companyName], references: [name])
  payslips        Payslip[]
  createdAt       DateTime  @default(now())
}

model Payslip {
  id           String     @id @default(uuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [employee])
  gross        Float
  net          Float
  deductions   String? // JSON
  pdfUrl       String?
  status       String     @default("Draft")
}

// ==========================================
// SALES ORDER MANAGEMENT
// ==========================================
model SalesOrder {
  pickLists       PickList[]
  id              String           @id @default(uuid())
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  d2cCustomerId   String?
  d2cCustomer     D2CCustomer?     @relation(fields: [d2cCustomerId], references: [id])
  companyName     String?
  company         Company?         @relation(fields: [companyName], references: [name])
  transactionDate DateTime         @default(now())
  status          String           @default("Draft")
  grandTotal      Float            @default(0.0)
  channel         String           @default("D2C")
  addressJson     String?
  items           SalesOrderItem[]
  returns         Return[]
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  itemCode     String
  item         Item       @relation(fields: [itemCode], references: [itemCode])
  qty          Float
  rate         Float
  discount     Float      @default(0.0)
  amount       Float
}

