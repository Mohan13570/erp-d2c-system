  commodity        String
  hsCode           String?
  description      String?
  grossWeight      Float?
  netWeight        Float?
  chargeableWeight Float?
  volume           Float?
  packagesCount    Int?
  packageType      String?
  hazmatClass      String?

  cargoName            String?
  commodityCategory    String?
  unNumber             String?
  cargoNature          String?
  cargoType            String?
  countryOfOrigin      String?
  countryOfDestination String?
  declaredValue        Float?
  currency             String?
  insuranceRequired    Boolean @default(false)
  insuranceValue       Float?
  incoterms            String?

