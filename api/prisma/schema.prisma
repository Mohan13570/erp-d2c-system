model OceanInvoice {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  invoiceNumber String @unique
  type          String // Receivable (Customer Invoice), Payable (Vendor Bill), Credit Note, Debit Note
  status        String @default("Draft") // Draft, Issued, Partially Paid, Paid, Void

  partyName String // Billed To or Billed By

  currencyId   String?
  currency     Currency? @relation(fields: [currencyId], references: [code])
