  description String?

  sealNumber String?
  sealTypeId String?
  sealType   SealType? @relation(fields: [sealTypeId], references: [id])

  location    String?
  performedBy String

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PortOperationCall {
  id     String @id @default(uuid())
  portId String
  port   Port   @relation("PortOperationCallRelation", fields: [portId], references: [id])

  vesselId String
  vessel   Vessel @relation(fields: [vesselId], references: [id])

  voyageId String
  voyage   Voyage @relation(fields: [voyageId], references: [id])

  terminalId String?
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  berthId String?
  berth   Berth?  @relation(fields: [berthId], references: [id])

  craneAssigned String?

  eta DateTime?
  ata DateTime? // Actual Time of Arrival
  etd DateTime?
  atd DateTime?

  status          String  @default("Scheduled") // Scheduled, Arrived, Working, Departed, Delayed
  delayReason     String?
  congestionLevel String? // Low, Medium, High

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// MODULE 24 - OCEAN FINANCE & CUSTOMS
