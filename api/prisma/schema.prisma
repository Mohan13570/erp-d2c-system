// ==========================================
// MODULE 22 - OCEAN BOOKING & SHIPMENT
// ==========================================

model OceanBooking {
  id            String  @id @default(uuid())
  bookingNumber String  @unique
  status        String  @default("Draft") // Draft, Pending Approval, Confirmed, Gated In, Loaded
  isNvocc       Boolean @default(false)
  freightType   String // FCL, LCL, BreakBulk, RORO

  // Routing
  polId       String?
  pol         Port?   @relation("PolRelation", fields: [polId], references: [id])
  podId       String?
  pod         Port?   @relation("PodRelation", fields: [podId], references: [id])
  finalDestId String?
  finalDest   Port?   @relation("FinalDestRelation", fields: [finalDestId], references: [id])

  // Assets
  shippingLineId String?
  shippingLine   ShippingLine? @relation(fields: [shippingLineId], references: [id])
  vesselId       String?
  vessel         Vessel?       @relation(fields: [vesselId], references: [id])
  voyageId       String?
  voyage         Voyage?       @relation(fields: [voyageId], references: [id])

  // Parties (Text for flexibility, or relation if linked to CRM)
  shipper          String?
  consignee        String?
  notifyParty      String?
  freightForwarder String?

  // Timings
  expectedDeparture DateTime?
  expectedArrival   DateTime?

  // Relations
  cargos              OceanBookingCargo[]
  containers          OceanBookingContainer[]
  documents           OceanDocument[]
  events              OceanBookingEvent[]
  containerEvents     ContainerEvent[]
  customsDeclarations OceanCustomsDeclaration[]
  invoices            OceanInvoice[]
  alerts              OceanAlert[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OceanBookingCargo {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  cargoTypeId String?
  cargoType   CargoType? @relation(fields: [cargoTypeId], references: [id])
  description String

  weightKg      Float?
  volumeCbm     Float?
  quantity      Int?
  packageTypeId String?
  packageType   PackageType? @relation(fields: [packageTypeId], references: [id])

  // Hazmat / Special
  isDangerousGoods Boolean              @default(false)
  dgClassId        String?
  dgClass          DangerousGoodsClass? @relation(fields: [dgClassId], references: [id])

  isReefer       Boolean           @default(false)
  tempClassId    String?
  tempClass      TemperatureClass? @relation(fields: [tempClassId], references: [id])
  setTemperature Float?

  isDeleted Boolean @default(false)
}

model OceanBookingContainer {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  containerTypeId String?
  containerType   ContainerType? @relation(fields: [containerTypeId], references: [id])
  containerSizeId String?
  containerSize   ContainerSize? @relation(fields: [containerSizeId], references: [id])

  quantity  Int     @default(1)
  isDeleted Boolean @default(false)
}

model OceanDocument {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  documentType   String // MBL, HBL, DO, CO, BookingConfirmation
  documentNumber String?
  issuedDate     DateTime?
  payload        String? // JSON string of document data

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OceanBookingEvent {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  status      String
  description String
  performedBy String

  createdAt DateTime @default(now())
}

// ==========================================
// MODULE 23 - OCEAN CONTAINER & PORT OPS
// ==========================================

model ContainerAsset {
  id              String  @id @default(uuid())
  containerNumber String  @unique // e.g., HLXU1234567
  qrCode          String? @unique

  containerTypeId String
  containerType   ContainerType @relation(fields: [containerTypeId], references: [id])
  containerSizeId String
  containerSize   ContainerSize @relation(fields: [containerSizeId], references: [id])

  status    String @default("Available") // Available, Stuffed, In-Transit, Damaged, Repair
  condition String @default("Sound") // Sound, Damaged, Total Loss

  currentPortId String?
  currentPort   Port?   @relation("PortAssetRelation", fields: [currentPortId], references: [id])

  yardLocationId String?
  yardLocation   YardLocation? @relation(fields: [yardLocationId], references: [id])

  latitude  Float?
  longitude Float?
  lastPing  DateTime?

  events ContainerEvent[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YardLocation {
  id     String @id @default(uuid())
  portId String
  port   Port   @relation("PortYardRelation", fields: [portId], references: [id])

  block String
  row   String
  tier  String

  capacity   Int     @default(1)
  isOccupied Boolean @default(false)

  assets ContainerAsset[]

  isDeleted Boolean @default(false)
}

model ContainerEvent {
  id          String         @id @default(uuid())
  containerId String
  container   ContainerAsset @relation(fields: [containerId], references: [id])

  bookingId String?
  booking   OceanBooking? @relation(fields: [bookingId], references: [id])

  eventType   String // Gate In, Gate Out, Stuffing, Destuffing, Damage Inspected, Cleaned, Sealed, Transfer
  description String?

  sealNumber String?
  sealTypeId String?
  sealType   SealType? @relation(fields: [sealTypeId], references: [id])

  location    String?
  performedBy String

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PortOperationCall {
  id     String @id @default(uuid())
  portId String
  port   Port   @relation("PortOperationCallRelation", fields: [portId], references: [id])

  vesselId String
  vessel   Vessel @relation(fields: [vesselId], references: [id])

  voyageId String
  voyage   Voyage @relation(fields: [voyageId], references: [id])

  terminalId String?
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  berthId String?
  berth   Berth?  @relation(fields: [berthId], references: [id])

  craneAssigned String?

  eta DateTime?
  ata DateTime? // Actual Time of Arrival
  etd DateTime?
  atd DateTime?

  status          String  @default("Scheduled") // Scheduled, Arrived, Working, Departed, Delayed
  delayReason     String?
  congestionLevel String? // Low, Medium, High

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// MODULE 24 - OCEAN FINANCE & CUSTOMS
// ==========================================

model OceanCustomsDeclaration {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  billOfEntryNo  String?
  shippingBillNo String?

  portOfClearanceId String?
  portOfClearance   Port?   @relation("CustomsPortRelation", fields: [portOfClearanceId], references: [id])

  status          String @default("Pending") // Pending, Examined, Duty Paid, Cleared, Held
  totalDutyAmount Float  @default(0)
  totalTaxAmount  Float  @default(0)

  items OceanCustomsItem[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OceanCustomsItem {
  id            String                  @id @default(uuid())
  declarationId String
  declaration   OceanCustomsDeclaration @relation(fields: [declarationId], references: [id])

  hsCode      String
  description String

  declaredValue   Float
  dutyRatePercent Float
  calculatedDuty  Float

  taxRatePercent Float
  calculatedTax  Float

  isDeleted Boolean @default(false)
}

model OceanInvoice {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  invoiceNumber String @unique
  type          String // Receivable (Customer Invoice), Payable (Vendor Bill), Credit Note, Debit Note
  status        String @default("Draft") // Draft, Issued, Partially Paid, Paid, Void

  partyName String // Billed To or Billed By

  currencyId   String?
  currency     Currency? @relation(fields: [currencyId], references: [code])
  exchangeRate Float     @default(1)

  subTotal   Float @default(0)
  taxTotal   Float @default(0)
  grandTotal Float @default(0)
  amountDue  Float @default(0)

  dueDate    DateTime?
  issuedDate DateTime?

  lines    OceanInvoiceLine[]
  payments OceanPayment[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OceanInvoiceLine {
  id        String       @id @default(uuid())
  invoiceId String
  invoice   OceanInvoice @relation(fields: [invoiceId], references: [id])

  chargeMasterId String?
  chargeMaster   ChargeMaster? @relation(fields: [chargeMasterId], references: [id])

  description    String
  quantity       Float  @default(1)
  unitPrice      Float
  taxRatePercent Float  @default(0)
  taxAmount      Float  @default(0)
  lineTotal      Float

  isDeleted Boolean @default(false)
}

model OceanPayment {
  id        String       @id @default(uuid())
  invoiceId String
  invoice   OceanInvoice @relation(fields: [invoiceId], references: [id])

  paymentReference String?
  amount           Float
  paymentDate      DateTime @default(now())
  paymentMethod    String // Bank Transfer, Credit Card, Cheque
  status           String   @default("Completed")

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==========================================
// MODULE 25 - OCEAN TRACKING & ANALYTICS
// ==========================================

model OceanAlert {
  id         String   @id @default(uuid())
  entityType String // Vessel, Container, Booking
  entityId   String
  alertType  String // Port Congestion, Weather Delay, ETA Deviation, Document Missing
  severity   String // Low, Medium, High, Critical
  message    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking OceanBooking? @relation(fields: [entityId], references: [id])
}

model VesselLocation {
  id         String   @id @default(uuid())
  vesselId   String
  vessel     Vessel   @relation(fields: [vesselId], references: [id])
  latitude   Float
  longitude  Float
  heading    Float?
  speedKnots Float?
  timestamp  DateTime @default(now())
}

// ============================================================================
// PART 4: AIR FREIGHT FOUNDATION MODULE
// ============================================================================

model Airport {
  id               String                  @id @default(uuid())
  iataCode         String                  @unique
  icaoCode         String                  @unique
  name             String
  cityId           String?
  city             City?                   @relation(fields: [cityId], references: [id])
  terminals        AirportTerminal[]
  cargoTerminals   CargoTerminal[]
  runways          Runway[]
  handlingAgents   HandlingAgent[]
  groundHandlers   GroundHandlingCompany[]
  securityAgencies SecurityAgency[]
  customsOffices   AirCustomsOffice[]
  originRoutes     AirRoute[]              @relation("OriginAirport")
  destRoutes       AirRoute[]              @relation("DestAirport")
  bookingOrigins   AirBooking[]            @relation("BookingOrigin")
  bookingDests     AirBooking[]            @relation("BookingDest")
  routingFroms     AirRouting[]            @relation("RoutingFrom")
  routingTos       AirRouting[]            @relation("RoutingTo")
  gateAssignments  GateAssignment[]
  weatherAlerts    AirWeatherAlert[]
  isDeleted        Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model AirportTerminal {
  id           String  @id @default(uuid())
  airportId    String
  airport      Airport @relation(fields: [airportId], references: [id])
  name         String
  terminalType String // Passenger, Cargo, Both
  isDeleted    Boolean @default(false)
}

model CargoTerminal {
  id               String  @id @default(uuid())
  airportId        String
  airport          Airport @relation(fields: [airportId], references: [id])
  name             String
  handlingCapacity String
  isDeleted        Boolean @default(false)
}

model Runway {
  id          String  @id @default(uuid())
  airportId   String
  airport     Airport @relation(fields: [airportId], references: [id])
  designation String
  length      Float
  width       Float
  isDeleted   Boolean @default(false)
}

model AirlineAlliance {
  id        String    @id @default(uuid())
  name      String    @unique
  airlines  Airline[]
  isDeleted Boolean   @default(false)
}

model Airline {
  id         String           @id @default(uuid())
  iataCode   String           @unique
  icaoCode   String           @unique
  name       String
  allianceId String?
  alliance   AirlineAlliance? @relation(fields: [allianceId], references: [id])
  agents     AirlineAgent[]
  schedules  FlightSchedule[]
  uldOwned   ULDOwnership[]
  isDeleted  Boolean          @default(false)
}

model AirlineAgent {
  id             String  @id @default(uuid())
  airlineId      String
  airline        Airline @relation(fields: [airlineId], references: [id])
  name           String
  contactDetails String
  isDeleted      Boolean @default(false)
}

model AircraftType {
  id             String                  @id @default(uuid())
  iataCode       String                  @unique
  manufacturer   String
  model          String
  capacities     AircraftCapacity[]
  configurations AircraftConfiguration[]
  schedules      FlightSchedule[]
  isDeleted      Boolean                 @default(false)
}

model AircraftCapacity {
  id               String       @id @default(uuid())
  aircraftTypeId   String
  aircraftType     AircraftType @relation(fields: [aircraftTypeId], references: [id])
  maxPayloadVolume Float
  maxPayloadWeight Float
  isDeleted        Boolean      @default(false)
}

model AircraftConfiguration {
  id                String       @id @default(uuid())
  aircraftTypeId    String
  aircraftType      AircraftType @relation(fields: [aircraftTypeId], references: [id])
  configurationType String // Freighter, Passenger, Combi
  isDeleted         Boolean      @default(false)
}

model AirRoute {
  id                   String           @id @default(uuid())
  originAirportId      String
  originAirport        Airport          @relation("OriginAirport", fields: [originAirportId], references: [id])
  destinationAirportId String
  destinationAirport   Airport          @relation("DestAirport", fields: [destinationAirportId], references: [id])
  distance             Float
  schedules            FlightSchedule[]
  isDeleted            Boolean          @default(false)
}

model FlightSchedule {
  id              String                @id @default(uuid())
  airlineId       String
  airline         Airline               @relation(fields: [airlineId], references: [id])
  routeId         String
  route           AirRoute              @relation(fields: [routeId], references: [id])
  flightNumber    String
  aircraftTypeId  String
  aircraftType    AircraftType          @relation(fields: [aircraftTypeId], references: [id])
  daysOfWeek      String
  departureTime   DateTime
  arrivalTime     DateTime
  routings        AirRouting[]
  uldManifests    AirULDManifest[]
  loadingPlans    AircraftLoadingPlan[] @relation("FlightLoadPlan")
  gateAssignments GateAssignment[]
  trackings       AirFlightTracking[]
  isDeleted       Boolean               @default(false)
}

model AirCargoCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isDeleted   Boolean @default(false)
}

model ULDType {
  id          String           @id @default(uuid())
  iataCode    String           @unique // AKE, PMC
  description String?
  sizes       ULDSize[]
  ownership   ULDOwnership[]
  manifests   AirULDManifest[]
  isDeleted   Boolean          @default(false)
}

model ULDSize {
  id             String  @id @default(uuid())
  uldTypeId      String
  uldType        ULDType @relation(fields: [uldTypeId], references: [id])
  length         Float
  width          Float
  height         Float
  maxGrossWeight Float
  isDeleted      Boolean @default(false)
}

model ULDOwnership {
  id        String  @id @default(uuid())
  uldTypeId String
  uldType   ULDType @relation(fields: [uldTypeId], references: [id])
  airlineId String
  airline   Airline @relation(fields: [airlineId], references: [id])
  ownerCode String
  isDeleted Boolean @default(false)
}

model AirPalletType {
  id        String  @id @default(uuid())
  name      String  @unique
  maxWeight Float
  isDeleted Boolean @default(false)
}

model HandlingAgent {
  id        String  @id @default(uuid())
  name      String
  airportId String
  airport   Airport @relation(fields: [airportId], references: [id])
  isDeleted Boolean @default(false)
}

model GroundHandlingCompany {
  id        String  @id @default(uuid())
  name      String
  airportId String
  airport   Airport @relation(fields: [airportId], references: [id])
  isDeleted Boolean @default(false)
}

model SecurityAgency {
  id        String  @id @default(uuid())
  name      String
  airportId String
  airport   Airport @relation(fields: [airportId], references: [id])
  isDeleted Boolean @default(false)
}

model AirCustomsOffice {
  id         String  @id @default(uuid())
  officeCode String  @unique
  name       String
  airportId  String
  airport    Airport @relation(fields: [airportId], references: [id])
  isDeleted  Boolean @default(false)
}

// ============================================================================
// PART 5: AIR FREIGHT BOOKING & SHIPMENT MODULE
// ============================================================================

model AirBooking {
  id                      String  @id @default(uuid())
  bookingNumber           String  @unique
  originAirportId         String
  originAirport           Airport @relation("BookingOrigin", fields: [originAirportId], references: [id])
  destAirportId           String
  destAirport             Airport @relation("BookingDest", fields: [destAirportId], references: [id])
  shipperId               String?
  consigneeId             String?
  notifyPartyId           String?
  freightForwarderId      String?
  cargoAgentId            String?
  status                  String  @default("Draft") // Draft, Requested, Approved, Confirmed, Rejected, Cancelled
  totalGrossWeight        Float   @default(0)
  totalChargeableWeight   Float   @default(0)
  totalVolume             Float   @default(0)
  isDangerousGoods        Boolean @default(false)
  isPerishable            Boolean @default(false)
  isTemperatureControlled Boolean @default(false)
  isLiveAnimals           Boolean @default(false)
  isValuable              Boolean @default(false)

  items      AirBookingItem[]
  routings   AirRouting[]
  waybills   AirWaybill[]
  documents  AirDocument[]
  milestones AirShipmentMilestone[]

  financials       AirShipmentFinancials?
  chargeLines      AirChargeLine[]
  invoices         AirInvoice[]
  vendorBills      AirVendorBill[]
  customsDeclarations AirCustomsDeclaration[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AirBookingItem {
  id               String                @id @default(uuid())
  bookingId        String
  booking          AirBooking            @relation(fields: [bookingId], references: [id])
  description      String
  quantity         Int                   @default(1)
  length           Float // in cm
  width            Float // in cm
  height           Float // in cm
  grossWeight      Float // in kg
  chargeableWeight Float // in kg
  volume           Float // in cbm
  iataCode         String? // e.g. DGR, PER, AVI
  uldManifestId    String?
  uldManifest      AirULDManifest?       @relation("ManifestItems", fields: [uldManifestId], references: [id])
  operations       AirCargoOperation[]
  discrepancies    AirCargoDiscrepancy[]
  isDeleted        Boolean               @default(false)
}

model AirRouting {
  id               String          @id @default(uuid())
  bookingId        String
  booking          AirBooking      @relation(fields: [bookingId], references: [id])
  sequence         Int
  flightScheduleId String?
  flightSchedule   FlightSchedule? @relation(fields: [flightScheduleId], references: [id])
  fromAirportId    String
  fromAirport      Airport         @relation("RoutingFrom", fields: [fromAirportId], references: [id])
  toAirportId      String
  toAirport        Airport         @relation("RoutingTo", fields: [toAirportId], references: [id])
  status           String          @default("Scheduled") // Scheduled, Departed, Arrived
  isDeleted        Boolean         @default(false)
}

model AirWaybill {
  id        String     @id @default(uuid())
  bookingId String
  booking   AirBooking @relation(fields: [bookingId], references: [id])
  awbNumber String     @unique
  awbType   String // HAWB, MAWB
  issueDate DateTime   @default(now())
  status    String     @default("Issued")
  isDeleted Boolean    @default(false)
}

model AirDocument {
  id             String     @id @default(uuid())
  bookingId      String
  booking        AirBooking @relation(fields: [bookingId], references: [id])
  documentType   String // Commercial Invoice, Packing List, Certificate Of Origin, DGD, Security Declaration
  documentNumber String?
  fileUrl        String?
  uploadDate     DateTime   @default(now())
  status         String     @default("Uploaded") // Uploaded, Verified, Rejected
  isDeleted      Boolean    @default(false)
}

model AirShipmentMilestone {
  id            String     @id @default(uuid())
  bookingId     String
  booking       AirBooking @relation(fields: [bookingId], references: [id])
  milestoneCode String // e.g., RCS, DEP, ARR, RCF, DLV
  description   String
  location      String?
  timestamp     DateTime   @default(now())
  isDeleted     Boolean    @default(false)
}

// ============================================================================
// PART 6: AIR CARGO & AIRPORT OPERATIONS
// ============================================================================

model AirULDManifest {
  id               String          @id @default(uuid())
  uldNumber        String          @unique // e.g., AKE12345EK
  uldTypeId        String?
  uldType          ULDType?        @relation(fields: [uldTypeId], references: [id])
  flightScheduleId String?
  flightSchedule   FlightSchedule? @relation(fields: [flightScheduleId], references: [id])
  status           String          @default("Building") // Building, Built, Weighed, Loaded, Unloaded, Broken-down
  grossWeight      Float           @default(0)
  netWeight        Float           @default(0)
  tareWeight       Float           @default(0)
  sealNumber       String?
  isIntact         Boolean         @default(true)

  items        AirBookingItem[]      @relation("ManifestItems")
  loadingPlans AircraftLoadingPlan[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AircraftLoadingPlan {
  id               String         @id @default(uuid())
  flightScheduleId String
  flightSchedule   FlightSchedule @relation("FlightLoadPlan", fields: [flightScheduleId], references: [id])
  uldManifestId    String
  uldManifest      AirULDManifest @relation(fields: [uldManifestId], references: [id])
  position         String // e.g., FWD1, AFT2, BULK
  deck             String // Main, Lower
  status           String         @default("Planned") // Planned, Loaded, Unloaded
  loadedAt         DateTime?
  unloadedAt       DateTime?

  isDeleted Boolean @default(false)
}

model AirCargoOperation {
  id             String         @id @default(uuid())
  bookingItemId  String
  bookingItem    AirBookingItem @relation(fields: [bookingItemId], references: [id])
  operationType  String // Acceptance, Screening, ColdStorage, Transfer, Breakdown
  location       String
  operatorId     String?
  barcodeScanned String?
  qrCodeScanned  String?
  timestamp      DateTime       @default(now())
  remarks        String?

  isDeleted Boolean @default(false)
}

model AirCargoDiscrepancy {
  id              String         @id @default(uuid())
  bookingItemId   String
  bookingItem     AirBookingItem @relation(fields: [bookingItemId], references: [id])
  discrepancyType String // Damage, Shortage, Excess
  severity        String // Low, Medium, High
  description     String
  photoUrls       String? // Comma separated
  reportedAt      DateTime       @default(now())
  status          String         @default("Open") // Open, Investigating, Resolved

  isDeleted Boolean @default(false)
