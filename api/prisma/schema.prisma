  cargoTerminals   CargoTerminal[]
  runways          Runway[]
  handlingAgents   HandlingAgent[]
  groundHandlers   GroundHandlingCompany[]
  securityAgencies SecurityAgency[]
  customsOffices   AirCustomsOffice[]
  originRoutes     AirRoute[]              @relation("OriginAirport")
  destRoutes       AirRoute[]              @relation("DestAirport")
  bookingOrigins   AirBooking[]            @relation("BookingOrigin")
  bookingDests     AirBooking[]            @relation("BookingDest")
  routingFroms     AirRouting[]            @relation("RoutingFrom")
  routingTos       AirRouting[]            @relation("RoutingTo")
  gateAssignments  GateAssignment[]
  weatherAlerts    AirWeatherAlert[]
  isDeleted        Boolean                 @default(false)
  createdAt        DateTime                @default(now())
