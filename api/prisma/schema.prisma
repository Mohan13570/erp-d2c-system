  status    String @default("Available") // Available, Stuffed, In-Transit, Damaged, Repair
  condition String @default("Sound") // Sound, Damaged, Total Loss

  currentPortId String?
  currentPort   Port?   @relation("PortAssetRelation", fields: [currentPortId], references: [id])

  yardLocationId String?
  yardLocation   YardLocation? @relation(fields: [yardLocationId], references: [id])

  latitude  Float?
  longitude Float?
  lastPing  DateTime?

  events ContainerEvent[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YardLocation {
  id     String @id @default(uuid())
  portId String
