  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Lookups (Dynamic Dropdowns)
model LookupCategory {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  description String?
  values      LookupValue[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model LookupValue {
  id         String         @id @default(uuid())
  categoryId String
  category   LookupCategory @relation(fields: [categoryId], references: [id])
  code       String
  value      String
  sequence   Int            @default(0)
  status     String         @default("Active")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// ==========================================
// SYSTEM ADMINISTRATION & MONITORING
// ==========================================

model SystemHealth {
  id             String   @id @default(uuid())
  component      String // Database, Redis, Server, API
  status         String // Operational, Degraded, Down
  responseTimeMs Int      @default(0)
  lastChecked    DateTime @default(now())
  details        String? // JSON string for errors/warnings
}

model ServerMetrics {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  cpuUsage    Float    @default(0)
  memoryTotal Float    @default(0)
  memoryUsed  Float    @default(0)
  diskTotal   Float    @default(0)
  diskUsed    Float    @default(0)
  networkRx   Float    @default(0)
  networkTx   Float    @default(0)
  uptime      Float    @default(0)
}

model DatabaseMetrics {
  id                String   @id @default(uuid())
  timestamp         DateTime @default(now())
  activeConnections Int      @default(0)
  idleConnections   Int      @default(0)
  queryRate         Float    @default(0)
  slowQueries       Int      @default(0)
  deadlocks         Int      @default(0)
  dbSizeGb          Float    @default(0)
}

model RedisMetrics {
  id               String   @id @default(uuid())
  timestamp        DateTime @default(now())
  connectedClients Int      @default(0)
  memoryUsedMb     Float    @default(0)
  keyspaceHits     Int      @default(0)
  keyspaceMisses   Int      @default(0)
}

model QueueMetrics {
  id            String   @id @default(uuid())
  timestamp     DateTime @default(now())
  queueName     String
  activeJobs    Int      @default(0)
  waitingJobs   Int      @default(0)
  completedJobs Int      @default(0)
  failedJobs    Int      @default(0)
  delayedJobs   Int      @default(0)
}

model ApiMetrics {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  endpoint        String
  method          String
  requestCount    Int      @default(0)
  avgResponseTime Float    @default(0)
  p95ResponseTime Float    @default(0)
  errorCount      Int      @default(0)
}

model JobHistory {
  id         String    @id @default(uuid())
  jobId      String
  queueName  String
  name       String
  status     String // Completed, Failed
  startTime  DateTime
  endTime    DateTime?
  durationMs Int?
  attempts   Int       @default(1)
  error      String?
  result     String?
  createdAt  DateTime  @default(now())
}

model BackupHistory {
  id            String    @id @default(uuid())
  type          String // Full, Incremental
  status        String // InProgress, Completed, Failed
  filePath      String?
  fileSizeBytes BigInt?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?
  error         String?
}

model RestoreHistory {
  id          String    @id @default(uuid())
  backupId    String
  status      String // InProgress, Completed, Failed
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?
  error       String?
}

model SystemLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  level      String // INFO, WARN, ERROR, FATAL
  service    String // Api, Worker, Cron
  message    String
  metadata   String? // JSON
  stackTrace String?
}

model ApiLog {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  method       String
  path         String
  statusCode   Int
  durationMs   Int
  ipAddress    String?
  userAgent    String?
  userId       String?
  requestBody  String?
  responseBody String?
}

model ErrorLog {
  id         String    @id @default(uuid())
  timestamp  DateTime  @default(now())
  type       String // Validation, Database, Unhandled
  message    String
  stack      String?
  path       String?
  userId     String?
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
}

model PerformanceMetric {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  metricName String
  value      Float
  tags       String? // JSON
}

model SecurityEvent {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  eventType String // FailedLogin, BlockedIP, RateLimitExceeded
  severity  String // Low, Medium, High, Critical
  ipAddress String?
  userId    String?
  details   String?
}

model License {
  id           String   @id @default(uuid())
  licenseKey   String   @unique
  organization String
  tier         String // Professional, Enterprise
  validFrom    DateTime
  validUntil   DateTime
  maxUsers     Int      @default(10)
  modules      String // JSON array of activated modules
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model FeatureFlag {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  isEnabled    Boolean  @default(false)
  environments String // JSON array e.g. ["dev", "prod"]
  updatedAt    DateTime @updatedAt
}

model EnvironmentSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

// ActivityLog - Generic log for any entity
model ActivityLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String // Created, Updated, Deleted
  userId     String?
  details    String? // JSON of changes
  timestamp  DateTime @default(now())
}

// ==========================================
// INTEGRATION HUB & API GATEWAY
// ==========================================

model Integration {
  id          String                  @id @default(uuid())
  provider    String // SAP, Salesforce, Stripe
  category    String // ERP, CRM, Payment
  status      String                  @default("Inactive") // Active, Inactive, Error
  environment String                  @default("Production")
  credentials IntegrationCredential[]
  logs        IntegrationLog[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  createdBy   String?
}

model IntegrationCredential {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id])
  keyName       String
  keyValue      String // Needs encryption in service layer
  isSecret      Boolean     @default(true)
  updatedAt     DateTime    @updatedAt
}

model IntegrationLog {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id])
  direction     String // Inbound, Outbound
  status        String // Success, Failed
  payload       String? // JSON
  response      String? // JSON
  timestamp     DateTime    @default(now())
}

model GatewayApiKey {
  id           String    @id @default(uuid())
  name         String
  keyHash      String    @unique
  organization String?
  rateLimit    Int       @default(1000)
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model ApiToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String?
  scope     String? // JSON array
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Webhook {
  id        String           @id @default(uuid())
  name      String
  url       String
  events    String // JSON array e.g. ["order.created", "shipment.updated"]
  secret    String?
  isActive  Boolean          @default(true)
  history   WebhookHistory[]
  retries   WebhookRetry[]
  createdAt DateTime         @default(now())
}

model WebhookHistory {
  id         String   @id @default(uuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id])
  event      String
  payload    String // JSON
  status     String // Success, Failed
  statusCode Int?
  response   String?
  timestamp  DateTime @default(now())
}

model WebhookRetry {
  id          String   @id @default(uuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id])
  historyId   String?
  attempts    Int      @default(0)
  nextRetryAt DateTime
  status      String // Pending, Exhausted
}

// ==========================================
// IMPORT / EXPORT ENGINE
// ==========================================

model ImportHistory {
  id          String   @id @default(uuid())
  entity      String // e.g. Customer, Item
  fileName    String
  status      String // Processing, Completed, Failed
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errors      String? // JSON
  uploadedBy  String?
  timestamp   DateTime @default(now())
}

model ExportHistory {
  id          String   @id @default(uuid())
  entity      String
  format      String // CSV, XLSX, JSON
  status      String // Processing, Completed, Failed
  fileUrl     String?
  requestedBy String?
  timestamp   DateTime @default(now())
}

// ==========================================
// AI PLATFORM
// ==========================================

model AIProvider {
  id       String      @id @default(uuid())
  name     String      @unique // Gemini, OpenAI, Claude
  isActive Boolean     @default(true)
  apiKey   String? // Encrypted
  models   AIModel[]
  requests AIRequest[]
  usage    AIUsage[]
}

model AIModel {
  id              String      @id @default(uuid())
  providerId      String
  provider        AIProvider  @relation(fields: [providerId], references: [id])
  name            String // gpt-4, gemini-1.5-pro
  costPer1kTokens Float       @default(0.0)
  isActive        Boolean     @default(true)
  requests        AIRequest[]
}

model PromptTemplate {
  id          String          @id @default(uuid())
  name        String          @unique // e.g. "GenerateInvoice"
  description String?
  versions    PromptVersion[]
  createdAt   DateTime        @default(now())
}

model PromptVersion {
  id         String         @id @default(uuid())
  templateId String
  template   PromptTemplate @relation(fields: [templateId], references: [id])
  version    Int            @default(1)
  content    String
  isActive   Boolean        @default(false)
  createdAt  DateTime       @default(now())
}

model AIAgent {
  id           String  @id @default(uuid())
  name         String  @unique
  role         String // e.g. "Customer Support", "Data Analyst"
  systemPrompt String
  modelId      String?
  isActive     Boolean @default(true)
}

model AIRequest {
  id         String      @id @default(uuid())
  providerId String?
  provider   AIProvider? @relation(fields: [providerId], references: [id])
  modelId    String?
  model      AIModel?    @relation(fields: [modelId], references: [id])
  prompt     String
  response   String?
  status     String // Success, Failed
  durationMs Int?
  tokensUsed Int         @default(0)
  userId     String?
  timestamp  DateTime    @default(now())
}

model AIUsage {
  id            String     @id @default(uuid())
  providerId    String
  provider      AIProvider @relation(fields: [providerId], references: [id])
  date          DateTime   @default(now()) // Daily aggregation
  totalRequests Int        @default(0)
  totalTokens   Int        @default(0)
  estimatedCost Float      @default(0.0)
}

model AICost {
  id       String @id @default(uuid())
  month    String // "YYYY-MM"
  provider String
  cost     Float  @default(0.0)
}

