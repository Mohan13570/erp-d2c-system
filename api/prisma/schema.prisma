// ==========================================
// MODULE 22 - OCEAN BOOKING & SHIPMENT
// ==========================================

model OceanBooking {
  id            String  @id @default(uuid())
  bookingNumber String  @unique
  status        String  @default("Draft") // Draft, Pending Approval, Confirmed, Gated In, Loaded
  isNvocc       Boolean @default(false)
  freightType   String // FCL, LCL, BreakBulk, RORO

  // Routing
  polId       String?
  pol         Port?   @relation("PolRelation", fields: [polId], references: [id])
  podId       String?
  pod         Port?   @relation("PodRelation", fields: [podId], references: [id])
  finalDestId String?
  finalDest   Port?   @relation("FinalDestRelation", fields: [finalDestId], references: [id])

  // Assets
  shippingLineId String?
  shippingLine   ShippingLine? @relation(fields: [shippingLineId], references: [id])
  vesselId       String?
  vessel         Vessel?       @relation(fields: [vesselId], references: [id])
  voyageId       String?
  voyage         Voyage?       @relation(fields: [voyageId], references: [id])

  // Parties (Text for flexibility, or relation if linked to CRM)
  shipper          String?
  consignee        String?
  notifyParty      String?
  freightForwarder String?

  // Timings
  expectedDeparture DateTime?
  expectedArrival   DateTime?

  // Relations
  cargos              OceanBookingCargo[]
  containers          OceanBookingContainer[]
  documents           OceanDocument[]
  events              OceanBookingEvent[]
  containerEvents     ContainerEvent[]
  customsDeclarations OceanCustomsDeclaration[]
  invoices            OceanInvoice[]
  alerts              OceanAlert[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OceanBookingCargo {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  cargoTypeId String?
  cargoType   CargoType? @relation(fields: [cargoTypeId], references: [id])
  description String

  weightKg      Float?
  volumeCbm     Float?
  quantity      Int?
  packageTypeId String?
  packageType   PackageType? @relation(fields: [packageTypeId], references: [id])

  // Hazmat / Special
  isDangerousGoods Boolean              @default(false)
  dgClassId        String?
  dgClass          DangerousGoodsClass? @relation(fields: [dgClassId], references: [id])

  isReefer       Boolean           @default(false)
  tempClassId    String?
  tempClass      TemperatureClass? @relation(fields: [tempClassId], references: [id])
  setTemperature Float?

  isDeleted Boolean @default(false)
}

model OceanBookingContainer {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  containerTypeId String?
  containerType   ContainerType? @relation(fields: [containerTypeId], references: [id])
  containerSizeId String?
  containerSize   ContainerSize? @relation(fields: [containerSizeId], references: [id])

  quantity  Int     @default(1)
  isDeleted Boolean @default(false)
}

model OceanDocument {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  documentType   String // MBL, HBL, DO, CO, BookingConfirmation
  documentNumber String?
  issuedDate     DateTime?
  payload        String? // JSON string of document data

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OceanBookingEvent {
  id        String       @id @default(uuid())
  bookingId String
  booking   OceanBooking @relation(fields: [bookingId], references: [id])

  status      String
  description String
  performedBy String

  createdAt DateTime @default(now())
}

// ==========================================
// MODULE 23 - OCEAN CONTAINER & PORT OPS
// ==========================================

model ContainerAsset {
  id              String  @id @default(uuid())
  containerNumber String  @unique // e.g., HLXU1234567
  qrCode          String? @unique

  containerTypeId String
  containerType   ContainerType @relation(fields: [containerTypeId], references: [id])
  containerSizeId String
