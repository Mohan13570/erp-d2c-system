  speedKnots Float?
  timestamp  DateTime @default(now())
}

// ============================================================================
// PART 4: AIR FREIGHT FOUNDATION MODULE
// ============================================================================

model Airport {
  id               String                  @id @default(uuid())
  iataCode         String                  @unique
  icaoCode         String                  @unique
  name             String
  cityId           String?
  city             City?                   @relation(fields: [cityId], references: [id])
