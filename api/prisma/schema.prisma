model Vehicle {
  id            String  @id @default(uuid())
  plateNumber   String  @unique
  category      String? // e.g., 'Heavy Truck', 'Van'
  make          String?
  model         String?
  year          Int?
  type          String
  capacity      Float
  fuelType      String? // e.g., 'Diesel', 'Electric'
  tyreDetails   String?
  ownershipType String? @default("Owned") // Owned, Leased
  status        String  @default("Available")

  // Identifiers
  qrCode  String? @unique
  barcode String? @unique

  // Assignments
  assignedDriverId String?
  assignedDriver   Driver? @relation(fields: [assignedDriverId], references: [id])
  assignedShipment String?

  // Retirement / Soft Delete
  isRetired        Boolean   @default(false)
  retiredAt        DateTime?
  retirementReason String?

  // Relations
  trips         Trip[]
  maintenance   VehicleMaintenance[]
  fuelLogs      FuelLog[]
  GPSDevice     GPSDevice?
  TrackingAlert TrackingAlert[]
  documents     VehicleDocument[]
  auditLogs     VehicleAuditLog[]
  RouteLog      RouteLog[]
}

model VehicleDocument {
  id         String    @id @default(uuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id])
  type       String // 'RC', 'Insurance', 'Fitness', 'Emission'
  documentNo String?
  issueDate  DateTime?
  expiryDate DateTime?
  fileUrl    String?
  status     String    @default("Valid")
  createdAt  DateTime  @default(now())
}

model VehicleAuditLog {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  action      String // 'StatusChanged', 'DriverAssigned', 'Retired'
  description String
  timestamp   DateTime @default(now())
}

model Driver {
  id           String  @id @default(uuid())
  name         String
  phone        String?
  email        String? @unique
  passwordHash String? // For Mobile App Login

  // Licenses & Credentials
  licenseNo         String    @unique
  licenseExpiry     DateTime?
  medicalCertExpiry DateTime?

  // HR & Emergency
  emergencyContact String?
  emergencyPhone   String?
  bloodGroup       String?
  payrollId        String? @unique
  hourlyRate       Float?

  // Metrics & Status
  rating       Float? @default(5.0)
  status       String @default("Active") // Active, On Leave, Suspended, Terminated
  availability String @default("Available") // Available, On Duty, Resting

  // Relations
  trips            Trip[]
  performance      DriverPerformance[]
  assignedVehicles Vehicle[]

  documents  DriverDocument[]
  shifts     DriverShift[]
  violations DriverViolation[]
  auditLogs  DriverAuditLog[]
}

model DriverDocument {
  id         String    @id @default(uuid())
  driverId   String
  driver     Driver    @relation(fields: [driverId], references: [id])
  type       String // 'License', 'Medical', 'BackgroundCheck', 'Training'
  documentNo String?
  issueDate  DateTime?
  expiryDate DateTime?
  fileUrl    String?
  status     String    @default("Valid")
  createdAt  DateTime  @default(now())
}

model DriverShift {
  id         String    @id @default(uuid())
  driverId   String
  driver     Driver    @relation(fields: [driverId], references: [id])
  startTime  DateTime
  endTime    DateTime?
  dutyHours  Float?
  breakHours Float?    @default(0)
  status     String    @default("Active") // Active, Completed
}

model DriverViolation {
  id            String   @id @default(uuid())
  driverId      String
  driver        Driver   @relation(fields: [driverId], references: [id])
  date          DateTime @default(now())
  violationType String // 'Overspeeding', 'Harsh Braking', 'Traffic Ticket'
  description   String?
  penaltyAmount Float?   @default(0)
  deducted      Boolean  @default(false)
}

model DriverAuditLog {
  id          String   @id @default(uuid())
  driverId    String
  driver      Driver   @relation(fields: [driverId], references: [id])
  action      String // 'StatusChanged', 'LeaveApproved', 'PenaltyApplied'
  description String
  timestamp   DateTime @default(now())
}

model Trip {
  id         String @id @default(uuid())
  tripNumber String @unique @default(uuid()) // A readable number in production

  // Assignments
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  driverId  String
  driver    Driver  @relation(fields: [driverId], references: [id])

  // Route
  origin      String
  destination String

  // Timeline & Status
  status    String    @default("Planned") // Planned, Assigned, Dispatched, InTransit, Completed, Cancelled
  startTime DateTime?
  endTime   DateTime?

  // Logistics & Financials
  totalDistanceKm Float? @default(0)
  estimatedHours  Float?
  fuelCost        Float? @default(0)
  tollExpenses    Float? @default(0)
  otherExpenses   Float? @default(0)
  revenue         Float? @default(0)

  // Relations
  stops     TripStop[]
  events    TripEvent[]
  auditLogs TripAuditLog[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TripStop {
  id           String    @id @default(uuid())
  tripId       String
  trip         Trip      @relation(fields: [tripId], references: [id])
  type         String // 'Pickup' or 'Delivery'
  locationName String
  latitude     Float?
  longitude    Float?
  sequence     Int       @default(0)
  plannedTime  DateTime?
  actualTime   DateTime?
  status       String    @default("Pending") // Pending, Arrived, Completed, Skipped
}

model TripAuditLog {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id])
  action      String // 'Created', 'Assigned', 'StatusChanged'
  description String
  timestamp   DateTime @default(now())
}

model VehicleMaintenance {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  date        DateTime @default(now())
  description String
  cost        Float
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  date      DateTime @default(now())
  liters    Float
  cost      Float
}

