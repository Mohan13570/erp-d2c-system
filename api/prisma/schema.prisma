  id              String    @id @default(uuid())
  deviceId        String    @unique
  device          GPSDevice @relation(fields: [deviceId], references: [id])
  pollingRateSec  Int       @default(5)
  dataCompression Boolean   @default(true)
  speedLimitKmh   Float     @default(80)
