  rfqNumber        String                     @unique
  title            String
  prId             String?
  pr               ProcurementRequisition?    @relation(fields: [prId], references: [id])
  issueDate        DateTime                   @default(now())
  deadline         DateTime
  status           String                     @default("Open") // Open, Closed, Awarded
  terms            String?
  items            ProcurementRFQItem[]
  vendors          ProcurementRFQVendor[]
  responses        ProcurementRFQResponse[]
  comparisons      ProcurementRFQComparison[]
  vendorQuotations VendorQuotation[]
}

model ProcurementRFQItem {
  id                   String                @id @default(uuid())
  rfqId                String
  rfq                  ProcurementRFQ        @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  itemCode             String
  description          String
  quantity             Int
  uom                  String
  vendorQuotationItems VendorQuotationItem[]
}

model ProcurementRFQVendor {
  id        String         @id @default(uuid())
  rfqId     String
  rfq       ProcurementRFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor         @relation(fields: [vendorId], references: [id])
  status    String         @default("Invited") // Invited, Responded, Declined
  invitedAt DateTime       @default(now())
}

model ProcurementRFQResponse {
  id           String         @id @default(uuid())
  rfqId        String
  rfq          ProcurementRFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId     String
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  responseDate DateTime       @default(now())
  totalAmount  Float
  currency     String         @default("USD")
  validUntil   DateTime
  remarks      String?
  fileUrl      String?
}

model ProcurementRFQComparison {
  id          String         @id @default(uuid())
  rfqId       String
  rfq         ProcurementRFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  evaluatedBy String
  evalDate    DateTime       @default(now())
  data        String // JSON matrix of technical/commercial scores
  winnerId    String? // The vendorId of the awarded vendor
}

// ==========================================
// APPROVAL ENGINE
// ==========================================

model ApprovalRule {
  id         String  @id @default(uuid())
  entityType String // RFQ, Contract, PR
  minAmount  Float?
  maxAmount  Float?
  department String?
  level1Role String // e.g. "Department Manager"
  level2Role String? // e.g. "Finance Manager"
  level3Role String? // e.g. "General Manager"
  isActive   Boolean @default(true)
}

model ApprovalQueue {
  id           String        @id @default(uuid())
  entityType   String // RFQ, Contract, PR
  entityId     String
  requestedBy  String
  requestDate  DateTime      @default(now())
  currentLevel Int           @default(1)
  status       String        @default("Pending") // Pending, Approved, Rejected
  logs         ApprovalLog[]
}

model ApprovalLog {
  id         String        @id @default(uuid())
  queueId    String
  queue      ApprovalQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  approverId String
  action     String // Approved, Rejected
  comments   String?
  actionDate DateTime      @default(now())
}

// ==========================================
// PURCHASING OPERATIONS (PR, PO, GRN, RETURNS, INVOICE)
// ==========================================

model PurchaseRequisition {
  id             String                    @id @default(uuid())
  prNumber       String                    @unique
  department     String?
  projectId      String?
  warehouseId    String?
  type           String                    @default("Standard") // Standard, Emergency, Recurring
  priority       String                    @default("Medium") // Low, Medium, High, Critical
  costCenter     String?
  status         String                    @default("Draft") // Draft, Submitted, Approved, Rejected, PO_Created, Closed
  requestDate    DateTime                  @default(now())
  requiredDate   DateTime?
  totalEstAmount Float                     @default(0)
  currency       String                    @default("USD")
  comments       String?
  items          PurchaseRequisitionItem[]
}

model PurchaseRequisitionItem {
  id          String              @id @default(uuid())
  prId        String
  pr          PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)
  itemCode    String
  item        Item                @relation(fields: [itemCode], references: [itemCode])
  description String?
  quantity    Float
  uom         String?
  estPrice    Float?
}

model PurchaseOrder {
  asns                  AdvanceShipmentNotice[]
  id                    String                  @id @default(uuid())
  poNumber              String                  @unique
  vendorId              String
  vendor                Vendor                  @relation(fields: [vendorId], references: [id])
  companyName           String?
  company               Company?                @relation(fields: [companyName], references: [name])
  warehouseId           String?
  type                  String                  @default("Standard") // Standard, Blanket, Contract
  status                String                  @default("Draft") // Draft, Pending_Approval, Approved, Sent, Partial_Receipt, Closed, Cancelled
  orderDate             DateTime                @default(now())
  expectedDate          DateTime?
  currency              String                  @default("USD")
  subTotal              Float                   @default(0.0)
  taxAmount             Float                   @default(0.0)
  discount              Float                   @default(0.0)
  freight               Float                   @default(0.0)
  insurance             Float                   @default(0.0)
  grandTotal            Float                   @default(0.0)
  incoterms             String?
  shippingTerms         String?
  notes                 String?
  items                 POItem[]
  grns                  GoodsReceiptNote[]
  invoices              VendorInvoice[]
  returns               PurchaseReturn[]
  history               PurchaseOrderHistory[]
  ProcurementVendorBill ProcurementVendorBill[]
  vendorInteractions    VendorPOInteraction[]
  vendorFinanceInvoices VendorFinanceInvoice[]
}

model PurchaseOrderHistory {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  action          String
  userId          String
  timestamp       DateTime      @default(now())
  details         String?
}

model POItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemCode        String
  item            Item          @relation(fields: [itemCode], references: [itemCode])
  description     String?
  qty             Float
  qtyReceived     Float         @default(0)
  uom             String?
  rate            Float
  taxPercent      Float         @default(0)
  discountPercent Float         @default(0)
  amount          Float
}

model GoodsReceiptNote {
  putAwayTasks       PutAwayTask[]
  id                 String                @id @default(uuid())
  grnNumber          String                @unique
  purchaseOrderId    String
  purchaseOrder      PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  warehouseId        String?
  receivedDate       DateTime              @default(now())
  status             String                @default("Draft") // Draft, Inspected, Posted
  receivedBy         String?
  notes              String?
  items              GRNItem[]
  inspections        QualityInspection[]
  vendorVisibilities VendorGRNVisibility[]
}

model GRNItem {
  id                 String           @id @default(uuid())
  goodsReceiptNoteId String
  goodsReceiptNote   GoodsReceiptNote @relation(fields: [goodsReceiptNoteId], references: [id], onDelete: Cascade)
  itemCode           String
  item               Item             @relation(fields: [itemCode], references: [itemCode])
  batchNumber        String?
  serialNumber       String?
  expiryDate         DateTime?
  lotNumber          String?
  qtyReceived        Float
  qtyAccepted        Float            @default(0)
  qtyRejected        Float            @default(0)
  reasonForReject    String?
  putAwayBinId       String?
}

model QualityInspection {
  id                 String           @id @default(uuid())
  goodsReceiptNoteId String
  goodsReceiptNote   GoodsReceiptNote @relation(fields: [goodsReceiptNoteId], references: [id], onDelete: Cascade)
  inspectorId        String
  inspectionDate     DateTime         @default(now())
  status             String           @default("Pending") // Pending, Passed, Failed, Conditional
  checklistResults   String? // JSON
  comments           String?
}

model PurchaseReturn {
  id              String               @id @default(uuid())
  returnNumber    String               @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  vendorId        String
  returnDate      DateTime             @default(now())
  status          String               @default("Draft") // Draft, Shipped, Credit_Received
  reason          String
  type            String               @default("RTV") // RTV, Replacement, Repair
  totalValue      Float                @default(0)
  items           PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id          String         @id @default(uuid())
  returnId    String
  return      PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  itemCode    String
  item        Item           @relation(fields: [itemCode], references: [itemCode])
  qtyReturned Float
  uom         String?
  unitPrice   Float
}

model VendorInvoice {
  id              String         @id @default(uuid())
  invoiceNumber   String         @unique
  vendorId        String
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  invoiceDate     DateTime
  dueDate         DateTime
  totalAmount     Float
  currency        String         @default("USD")
  status          String         @default("Draft") // Draft, Matched, Hold, Approved, Paid
  matchStatus     String         @default("Pending") // Pending, 2-Way-Matched, 3-Way-Matched, Discrepancy
  notes           String?
  createdAt       DateTime       @default(now())
}

// ==========================================
// PROCUREMENT FINANCE & ANALYTICS
// ==========================================

model ProcurementVendorBill {
  id              String               @id @default(uuid())
  billNumber      String               @unique
  vendorId        String
  vendor          Vendor               @relation("ProcurementVendorBills", fields: [vendorId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  amount          Float
  taxAmount       Float                @default(0)
  totalAmount     Float
  currency        String               @default("USD")
  status          String               @default("Unpaid") // Unpaid, Partial, Paid, Cancelled, On_Hold
  dueDate         DateTime
  createdAt       DateTime             @default(now())
  payments        ProcurementPayment[]
}

model ProcurementPayment {
  id            String                @id @default(uuid())
  paymentNumber String                @unique
  vendorBillId  String
  vendorBill    ProcurementVendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)
  vendorId      String
  vendor        Vendor                @relation("ProcurementPayments", fields: [vendorId], references: [id])
  amount        Float
  method        String                @default("Bank Transfer") // Bank Transfer, UPI, Cheque, Credit Card
  reference     String?
  paymentDate   DateTime              @default(now())
  status        String                @default("Completed") // Pending, Completed, Failed
}

model VendorLedger {
  id              String   @id @default(uuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  transactionType String // Invoice, Payment, CreditNote, DebitNote
  referenceId     String
  debit           Float    @default(0)
  credit          Float    @default(0)
  balance         Float
  date            DateTime @default(now())
  description     String?
}

model BudgetMaster {
  id              String  @id @default(uuid())
  department      String?
  projectId       String?
  costCenter      String?
  fiscalYear      String
  totalBudget     Float
  consumedAmount  Float   @default(0)
  allocatedAmount Float   @default(0)
  currency        String  @default("USD")
  status          String  @default("Active") // Active, Exhausted, Frozen
}

model SpendAnalysis {
  id               String  @id @default(uuid())
  periodMonth      Int
  periodYear       Int
  categoryId       String?
  vendorId         String?
  department       String?
  spendAmount      Float
  transactionCount Int     @default(0)
  currency         String  @default("USD")
}

// ==========================================
// WAREHOUSE MASTER & SPATIAL Hierarchy
// ==========================================

model WarehouseZone {
  id            String           @id @default(uuid())
  zoneCode      String
  warehouseName String
  warehouse     Warehouse        @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
  type          String // Receiving, Storage, Picking, Packing, Dispatch
  temperature   String? // Control requirement
  blocks        WarehouseBlock[]

  @@unique([warehouseName, zoneCode])
}

model WarehouseBlock {
  id        String           @id @default(uuid())
  blockCode String
  zoneId    String
  zone      WarehouseZone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  aisles    WarehouseAisle[]

  @@unique([zoneId, blockCode])
}

model WarehouseAisle {
  id        String          @id @default(uuid())
  aisleCode String
  blockId   String
  block     WarehouseBlock  @relation(fields: [blockId], references: [id], onDelete: Cascade)
  racks     WarehouseRack[]

  @@unique([blockId, aisleCode])
}

model WarehouseRack {
  id       String           @id @default(uuid())
  rackCode String
  aisleId  String
  aisle    WarehouseAisle   @relation(fields: [aisleId], references: [id], onDelete: Cascade)
  shelves  WarehouseShelf[]

  @@unique([aisleId, rackCode])
}

model WarehouseShelf {
  id                String         @id @default(uuid())
  shelfCode         String
  rackId            String
  rack              WarehouseRack  @relation(fields: [rackId], references: [id], onDelete: Cascade)
  maxWeightCapacity Float?
  bins              WarehouseBin[]

  @@unique([rackId, shelfCode])
}

model WarehouseBin {
  pickListItems  PickListItem[]
  putAwayItems   PutAwayItem[]
  id             String         @id @default(uuid())
  binCode        String
  shelfId        String
  shelf          WarehouseShelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  barcode        String?        @unique
  volumeCapacity Float?
  weightCapacity Float?

  @@unique([shelfId, binCode])
}

model WarehouseFloor {
  id          String  @id @default(uuid())
  floorName   String
  description String?
}

// ==========================================
// WAREHOUSE ASSETS & RULES
// ==========================================

model WarehouseEquipment {
  id              String    @id @default(uuid())
  equipmentCode   String    @unique
  warehouseName   String
  warehouse       Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
  type            String // Forklift, Pallet Jack, Conveyor
  status          String    @default("Active") // Active, Maintenance, Retired
  lastServiceDate DateTime?
}

model LoadingBay {
  dispatches    ShipmentDispatch[]
  schedules     DockSchedule[]
  id            String             @id @default(uuid())
  bayCode       String
  warehouseName String
  warehouse     Warehouse          @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
  type          String // Inbound, Outbound, Both
  status        String             @default("Available") // Available, Occupied, Maintenance

  @@unique([warehouseName, bayCode])
}

model WarehouseShift {
  id            String    @id @default(uuid())
  shiftName     String
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
  startTime     String // e.g., 08:00
  endTime       String // e.g., 16:00
}

model WarehouseHoliday {
  id            String    @id @default(uuid())
  date          DateTime
  description   String?
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
}

model WarehouseSetting {
  id               String    @id @default(uuid())
  warehouseName    String    @unique
  warehouse        Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
  barcodeConfig    String    @default("CODE128")
  qrConfig         Boolean   @default(true)
  rfidConfig       Boolean   @default(false)
  pickingRule      String    @default("FIFO") // FIFO, LIFO, FEFO
  packingRule      String    @default("Standard")
  dispatchRule     String    @default("Standard")
  stockReservation Boolean   @default(true)
}

model WarehouseDocument {
  id            String    @id @default(uuid())
  title         String
  fileUrl       String
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
}

model WarehouseImage {
  id            String    @id @default(uuid())
  imageUrl      String
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
}

model SafetyRule {
  id            String    @id @default(uuid())
  rule          String
  isMandatory   Boolean   @default(true)
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name], onDelete: Cascade)
}

// ==========================================
// WAREHOUSE INBOUND OPERATIONS
// ==========================================

model AdvanceShipmentNotice {
  id                 String                      @id @default(uuid())
  asnNumber          String                      @unique
  purchaseOrderId    String
  purchaseOrder      PurchaseOrder               @relation(fields: [purchaseOrderId], references: [id])
  vendorId           String
  vendor             Vendor                      @relation(fields: [vendorId], references: [id])
  expectedArrival    DateTime
  carrierName        String?
  trackingNumber     String?
  status             String                      @default("Scheduled") // Scheduled, Arrived, Receiving, Completed
  createdAt          DateTime                    @default(now())
  gateEntries        GateEntry[]
  vendorInteractions VendorASNInteraction[]
  vendorAppointments VendorDeliveryAppointment[]
  vendorTrackings    VendorShipmentTracking[]
}

model DockSchedule {
  id                 String                      @id @default(uuid())
  bayId              String
  bay                LoadingBay                  @relation(fields: [bayId], references: [id], onDelete: Cascade)
  asnNumber          String?
  scheduledDate      DateTime
  startTime          String // "10:00"
  endTime            String // "12:00"
  status             String                      @default("Booked") // Booked, In-Progress, Completed
  vendorAppointments VendorDeliveryAppointment[]
}

model GateEntry {
  id            String                 @id @default(uuid())
  entryNumber   String                 @unique
  asnId         String?
  asn           AdvanceShipmentNotice? @relation(fields: [asnId], references: [id])
  driverName    String
  driverLicense String?
  vehicleNumber String
  sealNumber    String?
  entryTime     DateTime               @default(now())
  exitTime      DateTime?
  status        String                 @default("Checked-In") // Checked-In, Unloading, Departed
}

model PutAwayTask {
  id               String           @id @default(uuid())
  taskId           String           @unique
  grnId            String
  goodsReceiptNote GoodsReceiptNote @relation(fields: [grnId], references: [id])
  assignedTo       String?
  status           String           @default("Pending") // Pending, In-Progress, Completed
  createdAt        DateTime         @default(now())
  items            PutAwayItem[]
}

model PutAwayItem {
  id          String       @id @default(uuid())
  taskId      String
  task        PutAwayTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  itemCode    String
  item        Item         @relation(fields: [itemCode], references: [itemCode])
  qty         Float
  targetBinId String
  bin         WarehouseBin @relation(fields: [targetBinId], references: [id])
  status      String       @default("Pending") // Pending, Completed
}

// ==========================================
// ADVANCED INVENTORY MANAGEMENT
// ==========================================

model InventoryBatch {
  id          String    @id @default(uuid())
  itemCode    String
  item        Item      @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  batchNumber String    @unique
  mfgDate     DateTime?
  expiryDate  DateTime?
  qtyOriginal Float
  qtyCurrent  Float
  status      String    @default("Active") // Active, Expired, Recalled
  createdAt   DateTime  @default(now())
}

model InventorySerial {
  id            String   @id @default(uuid())
  itemCode      String
  item          Item     @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  serialNumber  String   @unique
  warehouseName String
  status        String   @default("In-Stock") // In-Stock, Sold, In-Transit, Damaged, Returned
  createdAt     DateTime @default(now())
}

model InventoryAdjustment {
  id            String   @id @default(uuid())
  itemCode      String
  item          Item     @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  warehouseName String
  adjustmentQty Float
  reason        String // Shrinkage, Damage, Found, Write-Off
  adjustedBy    String
  status        String   @default("Draft") // Draft, Posted
  createdAt     DateTime @default(now())
}

model InventoryTransfer {
  id            String    @id @default(uuid())
  transferId    String    @unique
  itemCode      String
  item          Item      @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  fromWarehouse String
  toWarehouse   String
  qty           Float
  status        String    @default("Pending") // Pending, In-Transit, Completed
  initiatedBy   String
  shippedDate   DateTime?
  receivedDate  DateTime?
}

model CycleCount {
  id            String           @id @default(uuid())
  countId       String           @unique
  warehouseName String
  status        String           @default("Scheduled") // Scheduled, Counting, Review, Reconciled
  assignedTo    String?
  scheduledDate DateTime
  items         CycleCountItem[]
  createdAt     DateTime         @default(now())
}

model CycleCountItem {
  id           String     @id @default(uuid())
  cycleCountId String
  cycleCount   CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  itemCode     String
  expectedQty  Float
  countedQty   Float?
  variance     Float?
  status       String     @default("Pending") // Pending, Counted, Adjusted
}

model InventoryValuationSnapshot {
  id            String   @id @default(uuid())
  snapshotDate  DateTime @default(now())
  itemCode      String
  warehouseName String
  qty           Float
  unitValue     Float
  totalValue    Float
  method        String // FIFO, LIFO, Weighted Average
}

model PickList {
  id           String         @id @default(uuid())
  pickNumber   String         @unique
  orderRef     String
  salesOrder   SalesOrder?    @relation(fields: [orderRef], references: [id])
  pickingType  String         @default("Single") // Single, Wave, Zone, Batch
  assignedZone String?
  assignedTo   String?
  status       String         @default("Pending") // Pending, Picking, Completed
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  items        PickListItem[]
  boxes        PackingBox[]
}

model PickListItem {
  id          String        @id @default(uuid())
  pickListId  String
  pickList    PickList      @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  itemCode    String
  item        Item          @relation(fields: [itemCode], references: [itemCode])
  fromBinId   String?
  bin         WarehouseBin? @relation(fields: [fromBinId], references: [id])
  qtyExpected Float
  qtyPicked   Float         @default(0)
  status      String        @default("Pending") // Pending, Picked
}

model PackingBox {
  id          String            @id @default(uuid())
  boxNumber   String            @unique
  pickListId  String
  pickList    PickList          @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  packingType String // Box, Pallet, Carton
  weight      Float?
  dimensions  String? // L x W x H
  labelUrl    String? // Barcode/QR Code image URL
  status      String            @default("Packed") // Packed, Dispatched
  dispatchId  String?
  dispatch    ShipmentDispatch? @relation(fields: [dispatchId], references: [id])
  createdAt   DateTime          @default(now())
}

model ShipmentDispatch {
  id           String         @id @default(uuid())
  dispatchNo   String         @unique
  driverName   String?
  vehicleNo    String?
  sealNumber   String?
  dockBayId    String?
  dockBay      LoadingBay?    @relation(fields: [dockBayId], references: [id])
  status       String         @default("Planned") // Planned, Loading, Dispatched, Delivered
  dispatchedAt DateTime?
  boxes        PackingBox[]
  proof        DispatchProof?
  createdAt    DateTime       @default(now())
}

model DispatchProof {
  id           String           @id @default(uuid())
  dispatchId   String           @unique
  dispatch     ShipmentDispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  receiverName String
  signatureUrl String?
  photoUrl     String?
  receivedAt   DateTime         @default(now())
}

model WarehouseAuditLog {
  id         String   @id @default(uuid())
  actionType String // PICK, PACK, DISPATCH, ADJUSTMENT
  entityType String // PickList, PackingBox
  entityId   String
  userId     String
  metadata   String? // JSON blob
  createdAt  DateTime @default(now())
}

// ==========================================
// FINANCE FOUNDATION
// ==========================================

model FinanceCostCenter {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  type        String   @default("Department") // Department, Warehouse, Fleet, Project, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model FinanceProfitCenter {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FinanceBankMaster {
  id       String              @id @default(uuid())
  bankCode String              @unique
  bankName String
  branches FinanceBankBranch[]
  isActive Boolean             @default(true)
}

model FinanceBankBranch {
  id         String               @id @default(uuid())
  bankId     String
  bank       FinanceBankMaster    @relation(fields: [bankId], references: [id])
  branchName String
  ifscCode   String?
  swiftCode  String?
  accounts   FinanceBankAccount[]
}

model FinanceBankAccount {
  id             String            @id @default(uuid())
  branchId       String
  branch         FinanceBankBranch @relation(fields: [branchId], references: [id])
  accountNumber  String            @unique
  accountType    String            @default("Current")
  currency       String            @default("USD")
  currentBalance Float             @default(0.0)
  isActive       Boolean           @default(true)
}

// ==========================================
// CHART OF ACCOUNTS
// ==========================================

model FinanceAccountGroup {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  parentGroup String?
  category    String // Asset, Liability, Equity, Revenue, Expense
  accounts    ChartOfAccount[]
}

model ChartOfAccount {
  id             String              @id @default(uuid())
  accountCode    String              @unique
  accountName    String
  groupId        String
  group          FinanceAccountGroup @relation(fields: [groupId], references: [id])
  parentId       String?
  parent         ChartOfAccount?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       ChartOfAccount[]    @relation("AccountHierarchy")
  accountType    String // Control, Ledger, Bank, Cash, Tax
  currency       String              @default("USD")
  openingBalance Float               @default(0.0)
  currentBalance Float               @default(0.0)
  isActive       Boolean             @default(true)

  apLedgers     APLedger[]
  arLedgers     ARLedger[]
  GLJournalLine GLJournalLine[]
}

// ==========================================
// ACCOUNTS PAYABLE (AP)
// ==========================================

model APInvoice {
  id          String          @id @default(uuid())
  invoiceNo   String          @unique
  vendorId    String // Links to Vendor.id implicitly
  invoiceDate DateTime
  dueDate     DateTime
  totalAmount Float           @default(0.0)
  paidAmount  Float           @default(0.0)
  currency    String          @default("USD")
  status      String          @default("Draft") // Draft, Approved, Partially Paid, Paid, Overdue
  matchStatus String          @default("Pending") // For 2-way/3-way matching
  invoiceType String          @default("Standard") // Standard, Freight, Ocean, Air, Warehouse, Customs
  items       APInvoiceItem[]
  payments    APPayment[]
  createdAt   DateTime        @default(now())
}

model APInvoiceItem {
  id           String    @id @default(uuid())
  invoiceId    String
  invoice      APInvoice @relation(fields: [invoiceId], references: [id])
  description  String
  quantity     Float
  unitPrice    Float
  taxAmount    Float     @default(0.0)
  total        Float
  costCenterId String?
}

model APPayment {
  id            String    @id @default(uuid())
  paymentNo     String    @unique
  invoiceId     String
  invoice       APInvoice @relation(fields: [invoiceId], references: [id])
  amount        Float
  paymentDate   DateTime  @default(now())
  paymentMode   String // Bank Transfer, Cash, Cheque, UPI
  referenceNo   String?
  bankAccountId String?
  status        String    @default("Completed")
}

model APLedger {
  id           String         @id @default(uuid())
  vendorId     String
  accountId    String
  account      ChartOfAccount @relation(fields: [accountId], references: [id])
  postingDate  DateTime       @default(now())
  documentType String // Invoice, Payment, CreditNote
  documentNo   String
  debit        Float          @default(0.0)
  credit       Float          @default(0.0)
  balance      Float          @default(0.0)
  narration    String?
}

model APCreditNote {
  id         String   @id @default(uuid())
  noteNumber String   @unique
  vendorId   String
  invoiceId  String?
  amount     Float
  reason     String?
  date       DateTime @default(now())
  status     String   @default("Open") // Open, Applied
}

// ==========================================
// ACCOUNTS RECEIVABLE (AR)
// ==========================================

model ARInvoice {
  id          String          @id @default(uuid())
  invoiceNo   String          @unique
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id])
  invoiceDate DateTime
  dueDate     DateTime
  totalAmount Float           @default(0.0)
  paidAmount  Float           @default(0.0)
  currency    String          @default("USD")
  status      String          @default("Draft") // Draft, Approved, Sent, Partially Paid, Paid, Overdue
  invoiceType String          @default("Standard") // Standard, Freight, Storage, Fleet, Container
  items       ARInvoiceItem[]
  payments    ARPayment[]
  createdAt   DateTime        @default(now())
}

model ARInvoiceItem {
  id             String    @id @default(uuid())
  invoiceId      String
  invoice        ARInvoice @relation(fields: [invoiceId], references: [id])
  description    String
  quantity       Float
  unitPrice      Float
  taxAmount      Float     @default(0.0)
  total          Float
  profitCenterId String?
}

model ARPayment {
  id            String    @id @default(uuid())
  receiptNo     String    @unique
  invoiceId     String
  invoice       ARInvoice @relation(fields: [invoiceId], references: [id])
  amount        Float
  paymentDate   DateTime  @default(now())
  paymentMode   String
  referenceNo   String?
  bankAccountId String?
  status        String    @default("Completed")
}

model ARLedger {
  id           String         @id @default(uuid())
  customerId   String
  accountId    String
  account      ChartOfAccount @relation(fields: [accountId], references: [id])
  postingDate  DateTime       @default(now())
  documentType String // Invoice, Receipt, CreditNote
  documentNo   String
  debit        Float          @default(0.0)
  credit       Float          @default(0.0)
  balance      Float          @default(0.0)
  narration    String?
}

model ARCollectionAlert {
  id         String   @id @default(uuid())
  customerId String
  invoiceId  String
  type       String // Reminder, Overdue, Penalty
  message    String
  date       DateTime @default(now())
  status     String   @default("Pending") // Pending, Sent, Escalated
}

model ARCreditNote {
  id         String   @id @default(uuid())
  noteNumber String   @unique
  customerId String
  invoiceId  String?
  amount     Float
  reason     String?
  date       DateTime @default(now())
  status     String   @default("Open") // Open, Applied
}

// ==========================================
// GENERAL LEDGER & JOURNALS
// ==========================================

model GLJournalEntry {
  id           String   @id @default(uuid())
  journalNo    String   @unique
  postingDate  DateTime
  documentDate DateTime @default(now())
  reference    String?
  narration    String
  currency     String   @default("USD")
  exchangeRate Float    @default(1.0)
  totalDebit   Float    @default(0.0)
  totalCredit  Float    @default(0.0)
  status       String   @default("Draft") // Draft, Approved, Posted, Reversed
  sourceModule String   @default("Manual") // Manual, AP, AR, Procurement, Inventory
  createdBy    String?
  approvedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lines GLJournalLine[]
}

model GLJournalLine {
  id             String         @id @default(uuid())
  journalId      String
  journal        GLJournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId      String
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  costCenterId   String?
  profitCenterId String?
  description    String?
  debit          Float          @default(0.0)
  credit         Float          @default(0.0)
  baseDebit      Float          @default(0.0)
  baseCredit     Float          @default(0.0)
}

// ==========================================
// BANKING & CASH MANAGEMENT
// ==========================================

model BankReconciliation {
  id             String   @id @default(uuid())
  bankAccountId  String
  statementDate  DateTime
  closingBalance Float
  systemBalance  Float
  difference     Float
  status         String   @default("Draft") // Draft, Reconciled
  matchedCount   Int      @default(0)
  unmatchedCount Int      @default(0)
  createdAt      DateTime @default(now())
}

model FundTransfer {
  id            String   @id @default(uuid())
  transferNo    String   @unique
  fromAccountId String
  toAccountId   String
  amount        Float
  transferDate  DateTime
  reference     String?
  status        String   @default("Pending") // Pending, Completed, Failed
  journalId     String?
}

// ==========================================
// TAXATION & COMPLIANCE
// ==========================================

model TaxMaster {
  id        String  @id @default(uuid())
  taxCode   String  @unique
  taxName   String
  taxType   String // GST, VAT, TDS, ImportDuty
  rate      Float
  accountId String? // Liability/Asset Account for Posting
  isActive  Boolean @default(true)
}

model GSTTransaction {
  id            String @id @default(uuid())
  documentType  String // APInvoice, ARInvoice
  documentId    String
  taxType       String // CGST, SGST, IGST
  taxableAmount Float
  taxAmount     Float
  filingMonth   String // e.g., "2023-11"
  status        String @default("Pending") // Pending, Filed
}

// ==========================================
// REVENUE & EXPENSE MANAGEMENT
// ==========================================

model ExpenseCategory {
  id        String         @id @default(uuid())
  name      String         @unique
  accountId String? // GL Expense Account
  isActive  Boolean        @default(true)
  claims    ExpenseClaim[]
}

model ExpenseClaim {
  id         String          @id @default(uuid())
  claimNo    String          @unique
  employeeId String?
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount     Float
  claimDate  DateTime        @default(now())
  status     String          @default("Draft") // Draft, Approved, Paid, Rejected
  approvedBy String?
  journalId  String?
}

model FinancialPeriodLock {
  id                String   @id @default(uuid())
  periodName        String // e.g., "Nov-2023"
  startDate         DateTime
  endDate           DateTime
  isAPLocked        Boolean  @default(false)
  isARLocked        Boolean  @default(false)
  isGLLocked        Boolean  @default(false)
  isInventoryLocked Boolean  @default(false)
}

// Ensure ChartOfAccount has the opposite relation field for GLJournalLine
// We already added ChartOfAccount, so we use string references or we can just let Prisma warn us.
// Since ChartOfAccount already exists, Prisma will require 'GLJournalLine GLJournalLine[]' on ChartOfAccount.

model WarehouseAssignment {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  warehouseName String
  warehouse     Warehouse @relation(fields: [warehouseName], references: [name])
  assignedAt    DateTime  @default(now())
}

// ==========================================
// ENTERPRISE USER & EMPLOYEE MANAGEMENT
// ==========================================
model EmployeeProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  employeeCode  String  @unique
  employeeId    String? @unique
  firstName     String
  middleName    String?
  lastName      String
  preferredName String?
  displayName   String?

  profilePhoto  String?
  coverImage    String?
  gender        String?
  dob           DateTime?
  bloodGroup    String?
  nationality   String?
  religion      String?
  maritalStatus String?

  officialEmail   String?
  personalEmail   String?
  primaryMobile   String?
  secondaryMobile String?

  emergencyContact String?
  emergencyPhone   String?

  bio   String?
  notes String?

  profileCompletion  Float  @default(0.0)
  verificationStatus String @default("Pending")

  employmentInfo  EmploymentInformation?
  addresses       EmployeeAddress[]
  contacts        EmployeeContact[]
  documents       EmployeeDocument[]
  skills          EmployeeSkill[]
  languages       EmployeeLanguage[]
  education       EmployeeEducation[]
  experience      EmployeeExperience[]
  certifications  EmployeeCertification[]
  teamMemberships TeamMember[]
  assignments     EmployeeAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmploymentInformation {
  id         String          @id @default(uuid())
  employeeId String          @unique
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])

  companyId      String?
  branchId       String?
  departmentId   String?
  businessUnitId String?

  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  jobTitleId    String?
  jobTitle      JobTitle?    @relation(fields: [jobTitleId], references: [id])

  grade String?
  level String?

  reportingManagerId String?
  supervisorId       String?
  mentorId           String?

  employmentType   String    @default("Permanent") // Permanent, Contract, Consultant, Intern, Vendor
  joiningDate      DateTime?
  confirmationDate DateTime?
  probationEndDate DateTime?
  noticePeriod     Int? // in days
  exitDate         DateTime?

  workLocation String?
  workMode     String? @default("Office") // Office, Remote, Hybrid
  shift        String?
  workingHours String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Support tables: EmployeeAddress, EmployeeContact, EmployeeDocument, etc.
model EmployeeAddress {
  id          String          @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])
  addressType String          @default("Current") // Current, Permanent
  line1       String
  line2       String?
  city        String
  state       String?
  country     String
  postalCode  String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EmployeeContact {
  id          String          @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])
  relation    String
  name        String
  phone       String
  email       String?
  isEmergency Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EmployeeDocument {
  id             String          @id @default(uuid())
  employeeId     String
  employee       EmployeeProfile @relation(fields: [employeeId], references: [id])
  documentType   String // Passport, PAN, Aadhaar, Offer Letter, etc.
  documentNumber String?
  fileUrl        String
  version        String          @default("1.0")
  issueDate      DateTime?
  expiryDate     DateTime?
  status         String          @default("Active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model EmployeeSkill {
  id              String          @id @default(uuid())
  employeeId      String
  employee        EmployeeProfile @relation(fields: [employeeId], references: [id])
  skillName       String
  proficiency     String          @default("Intermediate")
  yearsExperience Float?
}

model EmployeeLanguage {
  id         String          @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])
  language   String
  read       Boolean         @default(true)
  write      Boolean         @default(true)
  speak      Boolean         @default(true)
  fluency    String          @default("Native")
}

model EmployeeEducation {
  id            String          @id @default(uuid())
  employeeId    String
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id])
  degree        String
  institution   String
  yearOfPassing Int
  grade         String?
}

model EmployeeExperience {
  id          String          @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])
  companyName String
  designation String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean         @default(false)
}

model EmployeeCertification {
  id                String          @id @default(uuid())
  employeeId        String
  employee          EmployeeProfile @relation(fields: [employeeId], references: [id])
  certificationName String
  issuingAuthority  String
  issueDate         DateTime
  expiryDate        DateTime?
  credentialId      String?
}

model Team {
  id          String       @id @default(uuid())
  name        String
  category    String       @default("Operations Team")
  description String?
  leaderId    String?
  members     TeamMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id         String          @id @default(uuid())
  teamId     String
  team       Team            @relation(fields: [teamId], references: [id])
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])
  role       String          @default("Member") // Leader, Member
  joinedAt   DateTime        @default(now())
}

model Designation {
  id                    String                  @id @default(uuid())
  name                  String                  @unique
  level                 Int                     @default(1)
  EmploymentInformation EmploymentInformation[]
}

model JobTitle {
  id                    String                  @id @default(uuid())
  title                 String                  @unique
  EmploymentInformation EmploymentInformation[]
}

model EmployeeAssignment {
  id         String          @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])
  entityType String // Company, Branch, Department, Project, Region
  entityId   String
  role       String?
  assignedAt DateTime        @default(now())
}

model UserPreference {
  id                String  @id @default(uuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id])
  language          String  @default("en")
  timezone          String  @default("UTC")
  dateFormat        String  @default("YYYY-MM-DD")
  timeFormat        String  @default("24h")
  currency          String  @default("USD")
  theme             String  @default("light")
  dashboardLayout   String? // Stringified JSON for SQLite compatibility
  notificationPrefs String? // Stringified JSON
}

model UserDevice {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  deviceType        String // Desktop, Laptop, Tablet, Mobile
  os                String?
  browser           String?
  ipAddress         String?
  macAddress        String?
  deviceFingerprint String?
  isTrusted         Boolean  @default(false)
  isBlocked         Boolean  @default(false)
  lastUsedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  ipAddress String?
  userAgent String?
  status    String   @default("Active") // Active, Expired, Terminated
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LoginHistory {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  ipAddress     String?
  userAgent     String?
  location      String?
  status        String // Success, Failed
  failureReason String?
  loginAt       DateTime @default(now())
}

// ==========================================
// SECURITY & AUTHENTICATION MODELS
// ==========================================
model SecurityPolicy {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])
  // If userId is null, it's a global policy

  passwordMinLength    Int     @default(12)
  requireUppercase     Boolean @default(true)
  requireNumbers       Boolean @default(true)
  requireSymbols       Boolean @default(true)
  passwordExpiryDays   Int     @default(90)
  passwordHistoryCount Int     @default(5)

  maxFailedLogins     Int @default(5)
  lockoutDurationMins Int @default(30)

  allowedIps       String? // JSON Array of CIDRs
  allowedCountries String? // JSON Array of ISO codes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  code      String
  type      String // Email, SMS
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MFA {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  secretKey   String?
  isEnabled   Boolean   @default(false)
  backupCodes String? // Hashed JSON Array
  verifiedAt  DateTime?
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
}

model APIKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  name       String
  keyHash    String    @unique
  scopes     String? // JSON Array of permissions
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model WebhookToken {
  id          String   @id @default(uuid())
  serviceName String
  tokenHash   String   @unique
  createdAt   DateTime @default(now())
}

model SecurityAlert {
  id          String   @id @default(uuid())
  severity    String // Low, Medium, High, Critical
  eventType   String // FailedLogin, MultipleIPs, RoleChange
  description String
  ipAddress   String?
  userAgent   String?
  userId      String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ==========================================
// WORKFLOW ENGINE & APPROVALS (PHASE 4)
// ==========================================
model Workflow {
  id          String              @id @default(uuid())
  name        String
  category    String              @default("General") // Procurement, HR, Finance
  description String?
  isActive    Boolean             @default(true)
  versions    WorkflowVersion[]
  executions  WorkflowExecution[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model WorkflowVersion {
  id         String         @id @default(uuid())
  workflowId String
  workflow   Workflow       @relation(fields: [workflowId], references: [id])
  version    Int
  status     String         @default("Draft") // Draft, Published, Archived
  nodes      WorkflowNode[]
  edges      WorkflowEdge[]
  createdAt  DateTime       @default(now())
}

model WorkflowNode {
  id        String          @id @default(uuid())
  versionId String
  version   WorkflowVersion @relation(fields: [versionId], references: [id])
  type      String // Start, End, Approval, Condition, Email, Script
  label     String
  positionX Float
  positionY Float
  config    String? // Stringified JSON containing conditions/approvers
  createdAt DateTime        @default(now())
}

model WorkflowEdge {
  id        String          @id @default(uuid())
  versionId String
  version   WorkflowVersion @relation(fields: [versionId], references: [id])
  sourceId  String
  targetId  String
  label     String?
  condition String? // Stringified JSON
}

model WorkflowExecution {
  id          String        @id @default(uuid())
  workflowId  String
  workflow    Workflow      @relation(fields: [workflowId], references: [id])
  status      String        @default("Running") // Running, Completed, Failed
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  logs        WorkflowLog[]
  approvals   Approval[]
}

model WorkflowLog {
  id          String            @id @default(uuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id])
  nodeId      String
  status      String // Success, Error
  message     String?
  timestamp   DateTime          @default(now())
}

model Approval {
  id          String             @id @default(uuid())
  executionId String?
  execution   WorkflowExecution? @relation(fields: [executionId], references: [id])
  entityType  String // PO, Invoice, Leave
  entityId    String
  status      String             @default("Pending") // Pending, Approved, Rejected, Escalated
  currentStep Int                @default(1)
  steps       ApprovalStep[]
  history     ApprovalHistory[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ApprovalStep {
  id           String    @id @default(uuid())
  approvalId   String
  approval     Approval  @relation(fields: [approvalId], references: [id])
  stepNumber   Int
  approverId   String // User or Role ID
  approverType String    @default("User") // User, Role, DepartmentHead
  status       String    @default("Pending")
  comments     String?
  actedAt      DateTime?
}

model ApprovalHistory {
  id         String   @id @default(uuid())
  approvalId String
  approval   Approval @relation(fields: [approvalId], references: [id])
  action     String
  actorId    String
  comments   String?
  timestamp  DateTime @default(now())
}

model WorkflowTask {
  id             String    @id @default(uuid())
  title          String
  description    String?
  priority       String    @default("Medium") // Low, Medium, High, Critical
  status         String    @default("Pending") // Pending, InProgress, Completed, Cancelled
  dueDate        DateTime?
  workflowNodeId String? // Link back to workflow if auto-generated

  assignments TaskAssignment[]
  comments    TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAssignment {
  id           String       @id @default(uuid())
  taskId       String
  task         WorkflowTask @relation(fields: [taskId], references: [id])
  assigneeId   String // User ID
  assigneeType String       @default("User")
  assignedAt   DateTime     @default(now())
}

model TaskComment {
  id        String       @id @default(uuid())
  taskId    String
  task      WorkflowTask @relation(fields: [taskId], references: [id])
  authorId  String
  text      String
  createdAt DateTime     @default(now())
}

// ==========================================
// NOTIFICATION & COMMUNICATION HUB (PHASE 5)
// ==========================================

model NotificationCategory {
  id            String                 @id @default(uuid())
  name          String                 @unique
  description   String?
  templates     NotificationTemplate[]
  notifications Notification[]
}

model NotificationTemplate {
  id              String               @id @default(uuid())
  categoryId      String
  category        NotificationCategory @relation(fields: [categoryId], references: [id])
  name            String
  subjectTemplate String?
  bodyTemplate    String // Supports {{variables}}
  channel         String // Email, SMS, WhatsApp, Push, InApp
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Notification {
  id           String                @id @default(uuid())
  categoryId   String?
  category     NotificationCategory? @relation(fields: [categoryId], references: [id])
  title        String
  message      String
  priority     String                @default("Normal") // Low, Normal, High, Urgent
  status       String                @default("Pending") // Pending, Scheduled, Sent, Failed
  scheduledFor DateTime?

  recipients NotificationRecipient[]
  deliveries NotificationDelivery[]

  createdAt DateTime @default(now())
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  isRead         Boolean      @default(false)
  readAt         DateTime?
}

model NotificationDelivery {
  id             String       @id @default(uuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id])
  channel        String // Email, SMS, WhatsApp, Push
  status         String // Delivered, Failed, Bounced
  providerMsgId  String?
  errorMessage   String?
  deliveredAt    DateTime?
  createdAt      DateTime     @default(now())
}

model Announcement {
  id             String    @id @default(uuid())
  title          String
  content        String
  type           String    @default("Info") // Info, Warning, Emergency, Holiday
  targetAudience String // Global, Department, Branch
  targetId       String? // Null if Global
  isPinned       Boolean   @default(false)
  validFrom      DateTime  @default(now())
  validUntil     DateTime?
  authorId       String
  createdAt      DateTime  @default(now())
}

model Campaign {
  id           String    @id @default(uuid())
  name         String
  subject      String?
  body         String
  channel      String // Email, SMS, WhatsApp
  status       String    @default("Draft") // Draft, Scheduled, Running, Completed
  scheduledFor DateTime?

  recipients CampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignRecipient {
  id         String    @id @default(uuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  email      String?
  phone      String?
  userId     String?
  status     String    @default("Pending") // Pending, Sent, Failed
  sentAt     DateTime?
}

model Reminder {
  id         String             @id @default(uuid())
  title      String
  entityType String // Invoice, Task, License, Birthday
  entityId   String
  message    String
  dueDate    DateTime
  schedules  ReminderSchedule[]
  createdAt  DateTime           @default(now())
}

model ReminderSchedule {
  id          String   @id @default(uuid())
  reminderId  String
  reminder    Reminder @relation(fields: [reminderId], references: [id])
  triggerTime DateTime
  channel     String
  isSent      Boolean  @default(false)
}

model EmailLog {
  id         String    @id @default(uuid())
  toAddress  String
  subject    String
  status     String // Sent, Failed, Bounced
  providerId String?
  openedAt   DateTime?
  clickedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model SMSLog {
  id          String   @id @default(uuid())
  phoneNumber String
  message     String
  status      String // Sent, Failed, Delivered
  providerId  String?
  createdAt   DateTime @default(now())
}

model WhatsAppLog {
  id           String   @id @default(uuid())
  phoneNumber  String
  templateName String?
  status       String // Sent, Delivered, Read, Failed
  providerId   String?
  createdAt    DateTime @default(now())
}

// ==========================================
// MASTER DATA MANAGEMENT (PHASE 6)
// ==========================================
// Note: Geography (Country, State, City, Port), Finance (Currency, Incoterm), 
