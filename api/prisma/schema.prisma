  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  documentType String // GST, PAN, Agreement
  documentUrl  String
  uploadDate   DateTime  @default(now())
  expiryDate   DateTime?
  status       String    @default("Pending Verification") // Verified, Rejected
}

model CustomerCompliance {
  id              String   @id @default(uuid())
  customerId      String   @unique
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  complianceScore Float    @default(0.0)
  riskLevel       String   @default("Unknown") // Low, Medium, High
  lastChecked     DateTime @default(now())
  isBlacklisted   Boolean  @default(false)
