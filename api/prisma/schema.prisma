model CustomerKYC {
  id         String    @id @default(uuid())
  customerId String    @unique
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kycStatus  String    @default("Pending") // Pending, Approved, Rejected
  verifiedBy String?
  verifiedAt DateTime?
  comments   String?
}

model CustomerUser {
  id           String    @id @default(uuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String    @default("Admin") // Admin, User, Finance
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
}

model CustomerInvitation {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email      String
  token      String   @unique
  status     String   @default("Sent") // Sent, Accepted, Expired
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

// Customer Logistics & Booking Models

model CustomerShipmentBooking {
  id            String   @id @default(uuid())
  bookingNumber String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  shipmentType  String // IMPORT, EXPORT, DOMESTIC, INTERNATIONAL
  transportMode String // OCEAN, AIR, ROAD, RAIL, MULTIMODAL
  status        String // DRAFT, PENDING, CONFIRMED, REJECTED, CANCELLED, COMPLETED
  incoterms     String?

  origin           String
  destination      String
  portOfLoading    String?
  portOfDischarge  String?
  pickupLocation   String?
  deliveryLocation String?

  items            CustomerBookingItem[]
  attachments      CustomerBookingAttachment[]
  cargos           CustomerCargo[]
  rfqs             CustomerRFQ[]
  pickupRequest    CustomerPickupRequest?
  deliveryRequest  CustomerDeliveryRequest?
  containerBooking CustomerContainerBooking?
  timeline         CustomerBookingTimeline[]
  approvals        CustomerBookingApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
}

model CustomerBookingItem {
  id          String                  @id @default(uuid())
  bookingId   String
  booking     CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unit        String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model CustomerBookingAttachment {
  id           String                  @id @default(uuid())
  bookingId    String
  booking      CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  documentType String // INVOICE, PACKING_LIST, PO, CERTIFICATE_OF_ORIGIN, ETC
  fileUrl      String
  fileName     String
  version      Int                     @default(1)
  createdAt    DateTime                @default(now())
}

model CustomerRFQ {
  id         String                  @id @default(uuid())
  rfqNumber  String                  @unique
  bookingId  String
  booking    CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status     String // OPEN, CLOSED, AWARDED, CANCELLED
  expiryDate DateTime?
  notes      String?

  vendors    CustomerRFQVendor[]
  quotations CustomerQuotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerRFQVendor {
  id        String      @id @default(uuid())
  rfqId     String
  rfq       CustomerRFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId  String
  status    String // PENDING, SUBMITTED, DECLINED
  createdAt DateTime    @default(now())
}

model CustomerQuotation {
  id              String      @id @default(uuid())
  quotationNumber String      @unique
  rfqId           String
  rfq             CustomerRFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId        String

  amount          Float
  currency        String
  validUntil      DateTime
  status          String // PENDING, ACCEPTED, REJECTED, REVISION_REQUESTED
  transitTimeDays Int?
  notes           String?
  version         Int      @default(1)

  comparisons CustomerQuotationComparison[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerQuotationComparison {
  id          String            @id @default(uuid())
  quotationId String
  quotation   CustomerQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  rfqId       String
  score       Float             @default(0.0) // Automated scoring based on price vs time
  rank        Int?
  createdAt   DateTime          @default(now())
}

model CustomerCargo {
  id        String                  @id @default(uuid())
  bookingId String
  booking   CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  cargoType String // GENERAL, HAZARDOUS, PERISHABLE, FRAGILE
  commodity String
  hsCode    String?

  totalWeight Float
  totalVolume Float
  weightUnit  String @default("KG")
  volumeUnit  String @default("CBM")

  isDangerousGoods  Boolean @default(false)
  isTemperatureCtrl Boolean @default(false)
  temperatureMin    Float?
  temperatureMax    Float?

  insuranceRequired Boolean @default(false)
  specialHandling   String?

  packages CustomerCargoPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerCargoPackage {
  id          String        @id @default(uuid())
  cargoId     String
  cargo       CustomerCargo @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  packageType String // PALLET, CARTON, CRATE, DRUM
  quantity    Int
  length      Float?
  width       Float?
  height      Float?
  weight      Float?
  createdAt   DateTime      @default(now())
}

model CustomerPickupRequest {
  id        String                  @id @default(uuid())
  bookingId String                  @unique
  booking   CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  address      String
  contactName  String
  contactPhone String
  instructions String?

  schedules CustomerPickupSchedule[]

  status    String // REQUESTED, SCHEDULED, COMPLETED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerPickupSchedule {
  id              String                @id @default(uuid())
  pickupRequestId String
  pickupRequest   CustomerPickupRequest @relation(fields: [pickupRequestId], references: [id], onDelete: Cascade)
  scheduledDate   DateTime
  timeWindowStart String?
  timeWindowEnd   String?
  isConfirmed     Boolean               @default(false)
  createdAt       DateTime              @default(now())
}

model CustomerDeliveryRequest {
  id        String                  @id @default(uuid())
  bookingId String                  @unique
  booking   CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  address       String
  contactName   String
  contactPhone  String
  preferredDate DateTime?
  instructions  String?

  status    String // PENDING, DISPATCHED, DELIVERED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerContainerBooking {
  id        String                  @id @default(uuid())
  bookingId String                  @unique
  booking   CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  containerType String // STANDARD, HIGH_CUBE, REEFER, OPEN_TOP
  containerSize String // 20FT, 40FT, 45FT
  quantity      Int

  status    String // REQUESTED, ALLOCATED, RESERVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerBookingApproval {
  id        String                  @id @default(uuid())
  bookingId String
  booking   CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  approverId String
  status     String // PENDING, APPROVED, REJECTED, ESCALATED
  comments   String?
  level      Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerBookingTimeline {
  id        String                  @id @default(uuid())
  bookingId String
  booking   CustomerShipmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  statusUpdate String
  description  String?
  location     String?

  createdAt DateTime @default(now())
}

// Phase 5: Customer Shipment Tracking & Logistics Visibility

model CustomerShipmentTracking {
  id        String @id @default(uuid())
  bookingId String @unique
  // If the booking exists in CustomerShipmentBooking, we use it. We'll map by ID since they might be in the same schema.

  status       String // IN_TRANSIT, DELAYED, DELIVERED, CUSTOMS_HOLD
  currentPhase String // ORIGIN_PORT, OCEAN_TRANSIT, DESTINATION_WAREHOUSE
  eta          DateTime?

  originCoordinates String? // Lat,Lng
  destCoordinates   String? // Lat,Lng

  events     CustomerTrackingEvent[]
  gpsHistory CustomerGPSLocation[]
  alerts     CustomerTrackingAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerTrackingEvent {
  id         String                   @id @default(uuid())
  trackingId String
  tracking   CustomerShipmentTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  eventType   String // PORT_ARRIVAL, CUSTOMS_CLEARED, DEPARTED
  description String
  location    String
  timestamp   DateTime @default(now())

  createdAt DateTime @default(now())
}

model CustomerGPSLocation {
  id         String                   @id @default(uuid())
  trackingId String
  tracking   CustomerShipmentTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float
  speedKmH  Float?
  heading   Float?
  timestamp DateTime @default(now())

  createdAt DateTime @default(now())
}

model CustomerWarehouseStatus {
  id        String @id @default(uuid())
  bookingId String // Linked conceptually

  warehouseName String
  status        String // RECEIVING, INSPECTED, RACKED, DISPATCH_READY
  rack          String?
  shelf         String?
  bin           String?

  inventoryCount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerContainerTracking {
  id              String @id @default(uuid())
  containerNumber String @unique
  bookingId       String

  status          String // AT_PORT, LOADED_ON_VESSEL, UNLOADED, IN_TRANSIT
  currentLocation String
  sealStatus      String // INTACT, BROKEN, INSPECTED

  eta DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerTrackingAlert {
  id         String                   @id @default(uuid())
  trackingId String
  tracking   CustomerShipmentTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  alertType String // DELAY, ROUTE_DEVIATION, CUSTOMS_HOLD
  message   String
  isRead    Boolean @default(false)

  createdAt DateTime @default(now())
}

model CustomerDeliveryProof {
  id        String @id @default(uuid())
  bookingId String @unique

  receiverName  String
  receiverPhone String?
  deliveryTime  DateTime

  signatureUrl String?
  photoUrl     String?
  notes        String?

  createdAt DateTime @default(now())
}

// Customer Finance & Billing Portal Schema

model CustomerInvoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique
  customerId    String // Link to Customer profile

  // Optional links to operational entities
  bookingId   String?
  containerId String?

  status String // DRAFT, GENERATED, SENT, PARTIALLY_PAID, PAID, OVERDUE, CANCELLED

  issueDate DateTime @default(now())
  dueDate   DateTime

  subtotal    Float @default(0.0)
  taxAmount   Float @default(0.0)
  totalAmount Float @default(0.0)
  amountPaid  Float @default(0.0)

  notes  String?
  pdfUrl String?

  items    CustomerInvoiceItem[]
  payments PaymentTransaction[]
  disputes InvoiceDispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerInvoiceItem {
  id        String          @id @default(uuid())
  invoiceId String
  invoice   CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  chargeType  String // FREIGHT, STORAGE, INSURANCE, CUSTOMS, HANDLING
  description String
  quantity    Float
  unitPrice   Float
  total       Float

  createdAt DateTime @default(now())
}

model PaymentTransaction {
  id             String           @id @default(uuid())
  transactionRef String           @unique
  invoiceId      String?
  invoice        CustomerInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customerId     String

  amount         Float
  paymentMethod  String // CREDIT_CARD, NET_BANKING, UPI, STRIPE, PAYPAL
  paymentGateway String?

  status      String // PENDING, SUCCESS, FAILED, REFUNDED
  paymentDate DateTime @default(now())
  receiptUrl  String?

  createdAt DateTime @default(now())
}

model CustomerLedger {
  id              String   @id @default(uuid())
  customerId      String
  transactionDate DateTime @default(now())

  type           String // DEBIT (Invoice), CREDIT (Payment)
  description    String
  amount         Float
  runningBalance Float

  referenceId String? // Link to Invoice or Payment ID

  createdAt DateTime @default(now())
}

model CustomerCreditLimit {
  id         String @id @default(uuid())
  customerId String @unique

  approvedLimit     Float @default(0.0)
  availableCredit   Float @default(0.0)
  utilizationAmount Float @default(0.0)

  status String // ACTIVE, SUSPENDED, UNDER_REVIEW

  requests CustomerCreditRequest[]

  updatedAt DateTime @updatedAt
}

model CustomerCreditRequest {
  id            String              @id @default(uuid())
  creditLimitId String
  creditLimit   CustomerCreditLimit @relation(fields: [creditLimitId], references: [id], onDelete: Cascade)

  requestedAmount Float
  reason          String
  status          String // PENDING, APPROVED, REJECTED

  createdAt DateTime @default(now())
}

model InvoiceDispute {
  id        String          @id @default(uuid())
  invoiceId String
  invoice   CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  reason      String
  description String
  status      String // OPEN, UNDER_INVESTIGATION, RESOLVED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// HR Attendance & Time Tracking Schema

model HRGeoFence {
  id           String  @id @default(uuid())
  locationName String
  latitude     Float
  longitude    Float
  radiusMeters Int     @default(100)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
}

model HRShift {
  id              String @id @default(uuid())
  name            String // MORNING, EVENING, NIGHT, ROTATIONAL
  startTime       String // HH:mm format
  endTime         String // HH:mm format
  gracePeriodMins Int    @default(15)
  halfDayMins     Int    @default(240) // 4 hours

  assignments HRShiftAssignment[]

  createdAt DateTime @default(now())
}

model HRShiftAssignment {
  id         String  @id @default(uuid())
  employeeId String
  shiftId    String
  shift      HRShift @relation(fields: [shiftId], references: [id])

  effectiveDate DateTime
  endDate       DateTime?

  createdAt DateTime @default(now())
}

model HRAttendance {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime

  status String // PRESENT, ABSENT, HALF_DAY, LATE, HOLIDAY, WEEKEND

  firstCheckIn DateTime?
  lastCheckOut DateTime?

  totalWorkMins  Int @default(0)
  totalBreakMins Int @default(0)

  isOvertime   Boolean @default(false)
  overtimeMins Int     @default(0)

  logs HRAttendanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
}

model HRAttendanceLog {
  id           String       @id @default(uuid())
  attendanceId String
  attendance   HRAttendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())
  type      String // IN, OUT, BREAK_START, BREAK_END
  method    String // MANUAL, GPS, BIOMETRIC, QR_CODE

  latitude   Float?
  longitude  Float?
  geoFenceId String?
  inGeoFence Boolean @default(false)

  deviceIp    String?
  deviceAgent String?
}

model HRAttendanceCorrection {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime

  requestedTime DateTime
  type          String // MISSED_IN, MISSED_OUT, WRONG_TIME
  reason        String

  status       String // PENDING, APPROVED, REJECTED
  approvedBy   String? // Manager ID
  approvalDate DateTime?

  createdAt DateTime @default(now())
}

model HROvertimeApproval {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime

  requestedMins Int
  approvedMins  Int?

  status     String // PENDING, APPROVED, REJECTED
  approvedBy String? // Manager ID

  createdAt DateTime @default(now())
}

// HR Leave Management Schema

model HRLeaveType {
  id               String  @id @default(uuid())
  code             String  @unique // CASUAL, SICK, EARNED, MATERNITY, LOP
  name             String
  description      String?
  isPaid           Boolean @default(true)
  isCarryForward   Boolean @default(false)
  maxCarryForward  Int     @default(0)
  requiresDocument Boolean @default(false)

  balances HRLeaveBalance[]
  requests HRLeaveRequest[]

  createdAt DateTime @default(now())
}

model HRLeaveBalance {
  id          String      @id @default(uuid())
  employeeId  String
  leaveTypeId String
  leaveType   HRLeaveType @relation(fields: [leaveTypeId], references: [id])

  accrued        Float @default(0)
  used           Float @default(0)
  carriedForward Float @default(0)
  balance        Float @default(0) // (accrued + carriedForward) - used

  year Int

  ledgers HRLeaveLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, leaveTypeId, year])
}

model HRLeaveLedger {
  id            String         @id @default(uuid())
  balanceId     String
  balanceRecord HRLeaveBalance @relation(fields: [balanceId], references: [id])

  transactionType String // ACCRUAL, DEDUCTION, ADJUSTMENT, ENCASHMENT
  amount          Float
  remarks         String?

  timestamp DateTime @default(now())
}

model HRLeaveRequest {
  id         String @id @default(uuid())
  employeeId String

  leaveTypeId String
  leaveType   HRLeaveType @relation(fields: [leaveTypeId], references: [id])

  startDate DateTime
  endDate   DateTime
  totalDays Float

  reason String
  status String // PENDING, APPROVED, REJECTED, CANCELLED

  backupEmployeeId String?
  documentUrl      String?

  approvedBy      String? // Manager ID
  approvalDate    DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HRHoliday {
  id          String   @id @default(uuid())
  name        String
  date        DateTime
  type        String // NATIONAL, REGIONAL, OPTIONAL
  isRecurring Boolean  @default(false)

  createdAt DateTime @default(now())
}

model HRWorkforcePlan {
  id           String   @id @default(uuid())
  departmentId String
  date         DateTime

  requiredHeadcount Int
  actualHeadcount   Int
  onLeave           Int
  deficit           Int

  aiSuggestion String?

  createdAt DateTime @default(now())

  @@unique([departmentId, date])
}

model ErpInvoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique
  customerId    String
  invoiceType   String // SHIPMENT, WAREHOUSE, CUSTOMS, MANUAL, PROFORMA
  status        String @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, SENT, OVERDUE, PAID, CANCELLED

  billingAddress  String?
  shippingAddress String?
  gstNumber       String?

  invoiceDate  DateTime @default(now())
  dueDate      DateTime
  currency     String   @default("USD")
  exchangeRate Float    @default(1.0)
  paymentTerms String?
  salesPerson  String?

  referenceNumber String?
  shipmentNumber  String?
  containerNumber String?

  subtotal      Float @default(0)
  discountTotal Float @default(0)
  taxTotal      Float @default(0)
  freightTotal  Float @default(0)
  grandTotal    Float @default(0)
  amountPaid    Float @default(0)

  items   ErpInvoiceItem[]
  charges ErpInvoiceCharge[]
  taxes   ErpInvoiceTax[]
  history ErpInvoiceHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpInvoiceItem {
  id        String     @id @default(uuid())
  invoiceId String
  invoice   ErpInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Float  @default(1)
  unit        String @default("PCS")
  unitPrice   Float

  discountPercent Float @default(0)
  discountAmount  Float @default(0)

  hsnCode String?
  sacCode String?

  amount Float // quantity * unitPrice - discountAmount
}

model ErpInvoiceCharge {
  id        String     @id @default(uuid())
  invoiceId String
  invoice   ErpInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  chargeType  String // FREIGHT, FUEL, LOADING, CUSTOMS, INSURANCE
  description String
  amount      Float
}

model ErpInvoiceTax {
  id        String     @id @default(uuid())
  invoiceId String
  invoice   ErpInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  taxType    String // GST, CGST, SGST, IGST, VAT
  taxPercent Float
  taxAmount  Float
}

model ErpInvoiceHistory {
  id        String     @id @default(uuid())
  invoiceId String
  invoice   ErpInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  action      String // CREATED, APPROVED, SENT, PAID
  notes       String?
  performedBy String
  createdAt   DateTime @default(now())
}

model ErpPricingContract {
  id             String   @id @default(uuid())
  contractNumber String   @unique
  customerId     String
  validFrom      DateTime
  validTo        DateTime
  currency       String   @default("USD")
  creditTerms    Int      @default(30)
  status         String   @default("ACTIVE") // ACTIVE, EXPIRED, DRAFT

  discountPercent Float  @default(0)
  discountType    String @default("VOLUME") // VOLUME, FLAT, SEASONAL

  rates ErpContractRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpContractRate {
  id         String             @id @default(uuid())
  contractId String
  contract   ErpPricingContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  originCode      String
  destinationCode String
  transportMode   String // OCEAN, AIR, ROAD

  unitType   String // KG, CBM, TEU, FEU, TRIP
  rateAmount Float

  minimumCharge Float  @default(0)
  maximumCharge Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpRateCard {
  id           String  @id @default(uuid())
  providerType String // CARRIER, VENDOR, STANDARD
  providerId   String? // Carrier ID or Vendor ID

  originCode      String
  destinationCode String
  transportMode   String // OCEAN, AIR, ROAD

  unitType String // KG, CBM, TEU, FEU, TRIP
  baseRate Float
  currency String @default("USD")

  validFrom DateTime
  validTo   DateTime

  status String @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpSurchargeRule {
  id            String @id @default(uuid())
  chargeType    String // FUEL, PEAK_SEASON, HAZMAT, OVERSIZE
  transportMode String // OCEAN, AIR, ROAD, ALL

  calculationType String // PERCENTAGE, FLAT_RATE, PER_UNIT
  amount          Float

  applicableZones String? // JSON array or comma separated
  validFrom       DateTime
  validTo         DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpMarginAnalysis {
  id         String @id @default(uuid())
  shipmentId String
  customerId String
  carrierId  String

  buyAmount     Float
  sellAmount    Float
  marginAmount  Float // sellAmount - buyAmount
  marginPercent Float // (marginAmount / sellAmount) * 100
  currency      String @default("USD")

  calculatedAt DateTime @default(now())
}

model ArCustomerProfile {
  id         String @id @default(uuid())
  customerId String @unique

  creditLimit     Float @default(0)
  usedCredit      Float @default(0)
  availableCredit Float @default(0) // creditLimit - usedCredit

  isOnCreditHold Boolean @default(false)
  riskScore      String  @default("LOW") // LOW, MEDIUM, HIGH

  ledgers     ArLedgerEntry[]
  collections ArCollectionActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArLedgerEntry {
  id        String            @id @default(uuid())
  profileId String
  profile   ArCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  transactionDate DateTime @default(now())
  transactionType String // INVOICE, PAYMENT, CREDIT_NOTE, DEBIT_NOTE
  referenceId     String // Invoice ID, Payment ID, etc.
  description     String

  debitAmount    Float @default(0) // Increases customer debt
  creditAmount   Float @default(0) // Decreases customer debt
  runningBalance Float // Balance immediately after this transaction

  currency String @default("USD")

  createdAt DateTime @default(now())
}

model ArPaymentAllocation {
  id           String @id @default(uuid())
  paymentRefId String // E.g. Bank Wire Ref
  invoiceId    String // Link to ErpInvoice

  allocatedAmount Float
  currency        String @default("USD")

  allocatedBy String
  createdAt   DateTime @default(now())
}

model ArCollectionActivity {
  id        String            @id @default(uuid())
  profileId String
  profile   ArCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  activityType     String // CALL, EMAIL, MEETING
  notes            String
  promiseToPayDate DateTime?
  promiseAmount    Float?

  status     String  @default("OPEN") // OPEN, CLOSED
  assignedTo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArDispute {
  id        String @id @default(uuid())
  invoiceId String

  disputeReason  String // PRICING, DAMAGE, TAX_ERROR
  disputedAmount Float
  status         String @default("PENDING") // PENDING, RESOLVED_CREDIT, RESOLVED_REJECTED

  notes    String?
  raisedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpBankAccount {
  id            String  @id @default(uuid())
  bankName      String
  accountNumber String  @unique
  routingNumber String?
  swiftCode     String?
  currency      String  @default("USD")

  currentBalance Float @default(0)

  status String @default("ACTIVE") // ACTIVE, FROZEN, CLOSED

  payments   ErpPaymentReceipt[]
  statements ErpBankStatementItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpPaymentReceipt {
  id            String @id @default(uuid())
  receiptNumber String @unique // e.g. REC-2026-001
  customerId    String

  paymentMethod   String // WIRE, CHEQUE, CASH, CREDIT_CARD, STRIPE
  referenceNumber String? // Bank transaction ref or cheque number
  amount          Float
  currency        String  @default("USD")

  status       String   @default("UNRECONCILED") // UNRECONCILED, RECONCILED, BOUNCED, REFUNDED
  receivedDate DateTime @default(now())

  bankAccountId String?
  bankAccount   ErpBankAccount? @relation(fields: [bankAccountId], references: [id])

  reconciliation ErpBankReconciliation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErpBankStatementItem {
  id            String         @id @default(uuid())
  bankAccountId String
  bankAccount   ErpBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  transactionDate DateTime
  description     String
  reference       String?

  amount         Float // Positive = Deposit, Negative = Withdrawal
  closingBalance Float?

  isReconciled   Boolean                @default(false)
  reconciliation ErpBankReconciliation?

  createdAt DateTime @default(now())
}

model ErpBankReconciliation {
  id String @id @default(uuid())

  statementItemId String               @unique
  statementItem   ErpBankStatementItem @relation(fields: [statementItemId], references: [id], onDelete: Cascade)

  receiptId String?            @unique
  receipt   ErpPaymentReceipt? @relation(fields: [receiptId], references: [id])

  // Could also link to an AP Payment to Vendor if it was an outgoing withdrawal
  // outgoingPaymentId String? 

  matchedBy      String // SYSTEM, or User ID
  matchedAt      DateTime @default(now())
  varianceAmount Float    @default(0) // Usually 0 if perfectly matched
}

model ErpCashBookTransaction {
  id              String   @id @default(uuid())
  transactionDate DateTime @default(now())
  type            String // CASH_IN, CASH_OUT
  category        String // PETTY_CASH, ADVANCE, MISC

  amount      Float
  description String
  recordedBy  String

  createdAt DateTime @default(now())
}

// ==========================================
// CUSTOMER BOOKING (LOGISTICS & FREIGHT)
// ==========================================

model CustomerBooking {
  id            String   @id @default(uuid())
  bookingNumber String   @unique // e.g., BKG-2023-001
  bookingDate   DateTime @default(now())
  bookingStatus String   @default("Draft") // Draft, Confirmed, Cancelled, In-Transit, Delivered
  bookingType   String   @default("Standard")
  bookingSource String   @default("Manual")

  // Customer Relations
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  customerRef String?
  internalRef String?

  // Organization
  salesExecutive String?
  salesTeam      String?
  branch         String?
  businessUnit   String?
  priority       String  @default("Normal")

  // Service
  serviceType String @default("Ocean Freight") // Ocean Freight, Air Freight, Road Transport, Rail, Multimodal
  tradeType   String @default("Export") // Import, Export, Domestic, International

  // Logistics Dates
  expectedPickup   DateTime?
  expectedDelivery DateTime?

  // Financial
  currency     String  @default("USD")
  paymentTerms String?

  // Additional Info
  bookingNotes        String?
  specialInstructions String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  // Relations
  sender      BookingSender?
  receiver    BookingReceiver?
  notifyParty BookingNotifyParty?
  billTo      BookingBillTo?
  cargos      BookingCargo[]
}

model BookingSender {
  id        String          @id @default(uuid())
  bookingId String          @unique
  booking   CustomerBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  companyName    String
  companyType    String?
  industry       String?
  taxNumber      String?
  registrationNo String?
  email          String?
  phone          String?

  // Contact
  contactPerson String?
  designation   String?
  mobileNumber  String?

  // Pickup Address
  line1      String?
  line2      String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  // Instructions
  pickupDate         DateTime?
  pickupInstructions String?
}

model BookingReceiver {
  id        String          @id @default(uuid())
  bookingId String          @unique
  booking   CustomerBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  companyName String
  taxNumber   String?
  email       String?
  phone       String?

  // Contact
  contactPerson String?
  mobileNumber  String?

  // Delivery Address
  line1      String?
  line2      String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  // Instructions
  deliveryDate         DateTime?
  deliveryInstructions String?
}

model BookingNotifyParty {
  id        String          @id @default(uuid())
  bookingId String          @unique
  booking   CustomerBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  companyName            String
  contactPerson          String?
  email                  String?
  phone                  String?
  line1                  String?
  city                   String?
  country                String?
  notificationPreference String  @default("Email")
}

model BookingBillTo {
  id        String          @id @default(uuid())
  bookingId String          @unique
  booking   CustomerBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  billingCompany String
  financeContact String?
  taxNumber      String?
  accountNumber  String?
  paymentTerms   String?
  creditLimit    Float?
  invoiceEmail   String?
  billingAddress String?
}

model BookingCargo {
  id        String          @id @default(uuid())
  bookingId String
  booking   CustomerBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  commodity   String?
  description String?
  hsCode      String?
  unNumber    String?

  packageType      String?
  numberOfPackages Int     @default(1)

  grossWeight      Float @default(0)
  netWeight        Float @default(0)
  chargeableWeight Float @default(0)
  volumeCBM        Float @default(0)

  length Float?
  width  Float?
  height Float?

  isTemperatureControlled Boolean @default(false)
  isDangerousGoods        Boolean @default(false)
  isFragile               Boolean @default(false)

  insuranceRequired Boolean @default(false)
  declaredValue     Float?

  marksAndNumbers   String?
  containerType     String?
  containerSize     String?
  containerQuantity Int     @default(0)
}

// ==========================================
// PACKAGE & FREIGHT CALCULATION ENGINE
// ==========================================

model RateCard {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  serviceType String // Ocean, Air, Road
  origin      String?
  destination String?
  currency    String   @default("USD")
  validFrom   DateTime
  validTo     DateTime
  status      String   @default("Active")

  items RateCardItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RateCardItem {
  id         String   @id @default(uuid())
  rateCardId String
  rateCard   RateCard @relation(fields: [rateCardId], references: [id], onDelete: Cascade)

  chargeCode      String // FREIGHT, FSC, THC, DOC
  chargeName      String
  calculationType String // PER_KG, PER_CBM, FLAT, PER_SHIPMENT, PERCENTAGE
  unitRate        Float
  minimumCharge   Float?
  maximumCharge   Float?

  // Tiering
  tierMinUnit Float?
  tierMaxUnit Float?
}

model PkgPackage {
  id         String @id @default(uuid())
  bookingId  String // Connects to CustomerBooking or BookingCargo
  packageRef String @unique

  packageType String // Pallet, Box, Carton, Drum
  quantity    Int     @default(1)
  description String?

  dimensions  PkgDimension?
  weight      PkgWeight?
  calculation PkgCalculation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PkgDimension {
  id        String     @id @default(uuid())
  packageId String     @unique
  package   PkgPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  length Float
  width  Float
  height Float
  unit   String @default("CM") // CM, IN
}

model PkgWeight {
  id        String     @id @default(uuid())
  packageId String     @unique
  package   PkgPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  actualWeight Float
  unit         String @default("KG") // KG, LBS
}

model PkgCalculation {
  id        String     @id @default(uuid())
  packageId String     @unique
  package   PkgPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  volumeCBM        Float
  volumeCFT        Float
  volumetricWeight Float
  chargeableWeight Float

  volumetricDivisor Float @default(6000)
}

model PricingRule {
  id        String  @id @default(uuid())
  ruleCode  String  @unique
  ruleName  String
  priority  Int     @default(1)
  condition String?
  action    String?
  status    String  @default("Active")
}

model FuelSurcharge {
  id            String    @id @default(uuid())
  carrierCode   String
  serviceType   String
  percentage    Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  status        String    @default("Active")
}

model InsuranceRule {
  id             String @id @default(uuid())
  commodityType  String
  ratePercentage Float
  minimumPremium Float
  status         String @default("Active")
}

model TaxRule {
  id            String @id @default(uuid())
  countryCode   String
  taxName       String
  taxPercentage Float
  appliesTo     String // FREIGHT, ALL
  status        String @default("Active")
}

model DiscountRule {
  id                String    @id @default(uuid())
  customerGroupId   String?
  customerId        String?
  discountPercent   Float
  maxDiscountAmount Float?
  validUntil        DateTime?
}

model BusinessRule {
  id         String  @id @default(uuid())
  ruleType   String // VALIDATION, ROUTING, CALCULATION
  ruleCode   String  @unique
  parameters String
  isActive   Boolean @default(true)
}

model ShipmentCharge {
  id        String @id @default(uuid())
  bookingId String

  totalFreight    Float  @default(0)
  totalSurcharges Float  @default(0)
  totalTaxes      Float  @default(0)
  totalDiscount   Float  @default(0)
  grandTotal      Float  @default(0)
  currency        String @default("USD")

  breakdowns ChargeBreakdown[]

  createdAt DateTime @default(now())
}

model ChargeBreakdown {
  id               String         @id @default(uuid())
  shipmentChargeId String
  shipmentCharge   ShipmentCharge @relation(fields: [shipmentChargeId], references: [id], onDelete: Cascade)

  chargeCode String
  chargeName String
  amount     Float
  currency   String  @default("USD")
  isTaxable  Boolean @default(true)
}

model CalculationHistory {
  id            String @id @default(uuid())
  bookingId     String
  calculatedBy  String // User ID or SYSTEM
  inputSnapshot String
  appliedRates  String
  finalAmount   Float
  currency      String

  calculatedAt DateTime @default(now())
}

// ==========================================
// SHIPMENT MANAGEMENT (PHASE 1)
// ==========================================

model ShipmentStatus {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., PENDING_PICKUP
  label       String // e.g., Pending Pickup
  description String?
  colorHex    String? // e.g., #3B82F6
  isTerminal  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ShipmentSummary {
  id             String   @id @default(uuid())
  date           DateTime @unique @default(now())
  totalShipments Int      @default(0)
  todayShipments Int      @default(0)
  pendingPickup  Int      @default(0)
  pickedUp       Int      @default(0)
  warehouse      Int      @default(0)
  inTransit      Int      @default(0)
  customs        Int      @default(0)
  outForDelivery Int      @default(0)
  delivered      Int      @default(0)
  completed      Int      @default(0)
  cancelled      Int      @default(0)
  delayed        Int      @default(0)
  revenue        Float    @default(0.0)
  profit         Float    @default(0.0)
  updatedAt      DateTime @updatedAt
}

model ShipmentDashboard {
  id             String   @id @default(uuid())
  userId         String   @unique
  customLayout   String? // JSON configuration for KPI cards
  defaultFilters String? // JSON default filters
  updatedAt      DateTime @updatedAt
}

model ShipmentActivity {
  id           String   @id @default(uuid())
  shipmentId   String
  shipmentRef  Shipment @relation(fields: [shipmentId], references: [id])
  activityType String // e.g., STATUS_CHANGE, DISPATCH, DRIVER_ASSIGNED
  description  String
  performedBy  String?
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())
}

// ==========================================
// SHIPMENT MANAGEMENT (PHASE 2)
// ==========================================

model ShipmentParty {
  id                 String   @id @default(uuid())
  shipmentId         String
  shipment           Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  partyType          String // SHIPPER, CONSIGNEE, NOTIFY_PARTY, BILL_TO
  company            String
  contactPerson      String?
  department         String?
  email              String?
  phone              String?
  mobile             String?
  country            String?
  city               String?
  address            String?
  location           String? // Pickup or Delivery Location
  instructions       String?
  notificationMethod String?
  paymentTerms       String?
  currency           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ShipmentNotes {
  id         String   @id @default(uuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  noteType   String // CUSTOMER, OPERATIONS, FINANCE, INTERNAL
  content    String
  author     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShipmentAssignment {
  id             String   @id @default(uuid())
  shipmentId     String
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  assignmentType String // DRIVER, VEHICLE, CONTAINER, WAREHOUSE
  assignedEntity String // Entity ID or Name
  assignedBy     String?
  assignedAt     DateTime @default(now())
  status         String   @default("ACTIVE") // ACTIVE, RELEASED
}

// ==========================================
// PACKAGE MANAGEMENT (PHASE 3)
// ==========================================

model ShipmentPackage {
  id              String        @id @default(uuid())
  cargoId         String
  cargo           ShipmentCargo @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  packageNumber   String        @unique
  packageType     String
  description     String?
  marksAndNumbers String?
  quantity        Int           @default(1)

  // Dimensions
  length        Float?
  width         Float?
  height        Float?
  dimensionUnit String @default("cm") // cm, mm, m, in, ft

  // Weights & Volumes (Calculated/Stored)
  grossWeight      Float?
  netWeight        Float?
  actualWeight     Float?
  weightUnit       String @default("kg") // kg, lbs
  volume           Float?
  cbm              Float?
  cft              Float?
  volumetricWeight Float?
  chargeableWeight Float?

  declaredValue  Float?
  insuranceValue Float?
  remarks        String?

  photos      PackagePhoto[]
  inspections PackageQualityInspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PackagePhoto {
  id          String          @id @default(uuid())
  packageId   String
  packageRef  ShipmentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  photoUrl    String
  photoType   String // PACKAGE, DAMAGE, LOADING
  description String?
  uploadedBy  String?
  createdAt   DateTime        @default(now())
}

model PackageQualityInspection {
  id                 String          @id @default(uuid())
  packageId          String
  packageRef         ShipmentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  inspectionRequired Boolean         @default(false)
  inspectionStatus   String          @default("PENDING")
  inspectionDate     DateTime?
  inspector          String?
  damageFound        Boolean         @default(false)
  damageDescription  String?
  packageCondition   String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model ContainerPlanning {
  id                String   @id @default(uuid())
  shipmentId        String   @unique
  shipment          Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  containerType     String
  containerSize     String
  maximumWeight     Float
  currentWeight     Float    @default(0.0)
  remainingCapacity Float
  loadPercentage    Float    @default(0.0)
  containerStatus   String   @default("PLANNED")
  updatedAt         DateTime @updatedAt
}

// ==========================================
// RESOURCE ALLOCATION & DISPATCH (PHASE 4)
// ==========================================

model ShipmentResourceValidation {
  id               String    @id @default(uuid())
  shipmentId       String    @unique
  shipment         Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  isVehicleValid   Boolean   @default(false)
  isDriverValid    Boolean   @default(false)
  isWarehouseValid Boolean   @default(false)
  isContainerValid Boolean   @default(false)
  isRouteValid     Boolean   @default(false)
  isTeamValid      Boolean   @default(false)
  overallStatus    String    @default("PENDING") // PENDING, VALIDATED, FAILED
  lastValidatedAt  DateTime?
  updatedAt        DateTime  @updatedAt
}

model VehicleAssignment {
  id              String   @id @default(uuid())
  shipmentId      String   @unique
  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  vehicleId       String?
  vehicleNumber   String?
  vehicleType     String?
  registrationNo  String?
  capacityWeight  Float?
  capacityVolume  Float?
  currentLocation String?
  fuelStatus      String?
  availability    String   @default("AVAILABLE")
  vehicleOwner    String?
  vehicleContact  String?
  remarks         String?
  assignedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DriverAssignment {
  id               String    @id @default(uuid())
  shipmentId       String    @unique
  shipment         Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driverId         String?
  driverName       String?
  licenseNumber    String?
  licenseExpiry    DateTime?
  mobileNumber     String?
  experienceYears  Int?
  currentStatus    String    @default("AVAILABLE")
  currentLocation  String?
  emergencyContact String?
  alternateDriver  String?
  remarks          String?
  assignedAt       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ShipmentWarehouseAssignment {
  id                 String   @id @default(uuid())
  shipmentId         String   @unique
  shipment           Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  originWarehouse    String?
  destWarehouse      String?
  crossDock          String?
  transitWarehouse   String?
  warehouseZone      String?
  warehouseManager   String?
  warehouseContact   String?
  loadingBay         String?
  instructions       String?
  capacityCBM        Float?
  currentUtilization Float?
  availableSpaceCBM  Float?
  assignedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContainerAssignment {
  id                String   @id @default(uuid())
  shipmentId        String   @unique
  shipment          Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  containerNumber   String?
  containerType     String?
  containerSize     String?
  sealNumber        String?
  containerOwner    String?
  containerStatus   String   @default("EMPTY")
  containerWeight   Float?
  capacityWeight    Float?
  availableCapacity Float?
  assignedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RouteAssignment {
  id                String   @id @default(uuid())
  shipmentId        String   @unique
  shipment          Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  routeName         String?
  originNode        String?
  destNode          String?
  distanceKm        Float?
  estTransitTimeHrs Float?
  preferredRoute    String?
  alternateRoute    String?
  tollRoute         Boolean  @default(false)
  avoidRoute        String?
  trafficPriority   String?
  assignedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DispatchPlan {
  id                String    @id @default(uuid())
  shipmentId        String    @unique
  shipment          Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  dispatchDate      DateTime?
  dispatchTime      String?
  loadingStartTime  DateTime?
  loadingEndTime    DateTime?
  departureTime     DateTime?
  expectedArrival   DateTime?
  estimatedDelivery DateTime?
  priority          String    @default("NORMAL")
  instructions      String?
  status            String    @default("DRAFT")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ==========================================
// PICKUP & DELIVERY (PHASE 5)
// ==========================================

model PickupRequest {
  id             String    @id @default(uuid())
  shipmentId     String    @unique
  shipment       Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  pickupStatus   String    @default("REQUESTED")
  pickupDate     DateTime?
  pickupTime     String?
  pickupTimeSlot String?
  pickupLocation String?
  pickupAddress  String?
  contactPerson  String?
  mobile         String?
  email          String?
  instructions   String?
  priority       String    @default("NORMAL")

  // Loading Operations
  loadingBay       String?
  loadingStartTime DateTime?
  loadingEndTime   DateTime?
  loadingDuration  String?
  loadedBy         String?
  vehicleCheck     Boolean   @default(false)
  containerCheck   Boolean   @default(false)
  packageCount     Int?
  sealNumber       String?

  // Checklist (Stored as JSON for flexibility or strict booleans)
  checklistData String? // JSON stringified checklist

  documents PickupDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PickupDocument {
  id              String        @id @default(uuid())
  pickupRequestId String
  pickupRequest   PickupRequest @relation(fields: [pickupRequestId], references: [id], onDelete: Cascade)
  documentType    String // COMMERCIAL_INVOICE, PACKING_LIST, DELIVERY_ORDER, GATE_PASS
  documentUrl     String
  version         Int           @default(1)
  uploadedBy      String?
  createdAt       DateTime      @default(now())
}

model DeliverySchedule {
  id              String    @id @default(uuid())
  shipmentId      String    @unique
  shipment        Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  deliveryStatus  String    @default("PENDING")
  deliveryDate    DateTime?
  deliveryTime    String?
  deliverySlot    String?
  deliveryAddress String?
  contactPerson   String?
  mobile          String?
  email           String?
  instructions    String?
  priority        String    @default("NORMAL")

  checklistData String? // JSON stringified delivery checklist

  proofOfDelivery ProofOfDelivery?
  exceptions      DeliveryException[]
  photos          DeliveryPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProofOfDelivery {
  id                 String           @id @default(uuid())
  deliveryScheduleId String           @unique
  deliverySchedule   DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id], onDelete: Cascade)
  receiverSignature  String? // Base64 or URL
  driverSignature    String? // Base64 or URL
  gpsLocation        String?
  deliveryTimestamp  DateTime?
  receiverName       String?
  receiverId         String?
  deliveryNotes      String?
  barcodeScanned     Boolean          @default(false)
  createdAt          DateTime         @default(now())
}

model DeliveryException {
  id                 String           @id @default(uuid())
  deliveryScheduleId String
  deliverySchedule   DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id], onDelete: Cascade)
  exceptionType      String // WRONG_ADDRESS, DAMAGED, REFUSED, DELAYED
  notes              String?
  correctiveAction   String?
  resolved           Boolean          @default(false)
  createdAt          DateTime         @default(now())
}

model DeliveryPhoto {
  id                 String           @id @default(uuid())
  deliveryScheduleId String
  deliverySchedule   DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id], onDelete: Cascade)
  photoUrl           String
  photoType          String // PROOF, DAMAGE, LOCATION
  uploadedBy         String?
  createdAt          DateTime         @default(now())
}

// ==========================================
// Phase 6.3: Live Tracking Engine
// ==========================================
model ShipmentLiveTracking {
  id         String   @id @default(uuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  altitude  Float?

  driverStatus  String?
  vehicleStatus String?

  timestamp DateTime @default(now())
}

// ==========================================
// Phase 6.4: Route Progress
// ==========================================
model ShipmentRouteProgress {
  id         String   @id @default(uuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  origin            String
  destination       String
  intermediateStops String? // JSON array string of stops

  distanceCovered   Float @default(0)
  distanceRemaining Float @default(0)

  estimatedArrival DateTime?
  actualArrival    DateTime?
  delayMinutes     Int       @default(0)

  updatedAt DateTime @updatedAt
}

// ==========================================
// Phase 8: Shipment Billing Integration
// ==========================================

model ShipmentBilling {
  id         String   @id @default(uuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  billingStatus String @default("PENDING") // PENDING, READY_FOR_BILLING, INVOICED, PARTIALLY_PAID, PAID
  currency      String @default("USD")

  subtotal      Float @default(0)
  totalTax      Float @default(0)
  totalDiscount Float @default(0)
  grandTotal    Float @default(0)

  chargeSummary ShipmentChargeSummary?
  taxDetails    ShipmentTax[]
  paymentStatus ShipmentPaymentStatus?
  invoices      ShipmentInvoice[]
  notes         FinancialNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShipmentChargeSummary {
  id        String          @id @default(uuid())
  billingId String          @unique
  billing   ShipmentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  baseFreight          Float @default(0)
  fuelSurcharge        Float @default(0)
  handlingCharges      Float @default(0)
  loadingCharges       Float @default(0)
  unloadingCharges     Float @default(0)
  warehouseCharges     Float @default(0)
  insuranceCharges     Float @default(0)
  customsCharges       Float @default(0)
  documentationCharges Float @default(0)
  otherCharges         Float @default(0)

  updatedAt DateTime @updatedAt
}

model ShipmentTax {
  id        String          @id @default(uuid())
  billingId String
  billing   ShipmentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  taxType    String // GST, CGST, SGST, IGST, VAT
  percentage Float
  amount     Float
}

model ShipmentInvoice {
  id        String          @id @default(uuid())
  billingId String
  billing   ShipmentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  invoiceNumber String   @unique
  invoiceDate   DateTime
  dueDate       DateTime
  status        String // DRAFT, ISSUED, PAID, CANCELLED
  paymentTerms  String
  pdfUrl        String?
  generatedBy   String

  createdAt DateTime @default(now())
}

model ShipmentPaymentStatus {
  id        String          @id @default(uuid())
  billingId String          @unique
  billing   ShipmentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  paidAmount        Float     @default(0)
  outstandingAmount Float     @default(0)
  lastPaymentDate   DateTime?
  status            String    @default("UNPAID") // UNPAID, PARTIALLY_PAID, PAID, OVERDUE
}

model FinancialNote {
  id        String          @id @default(uuid())
  billingId String
  billing   ShipmentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  type    String // BILLING, FINANCE, CUSTOMER, INTERNAL
  content String
  author  String

  createdAt DateTime @default(now())
}
